 {id:'208-20-1P',label:'208V 20A 1P',volts:208,amps:20,poles:1,bkw:4.16,ckw:3.33},
 {id:'208-20-2P',label:'208V 20A 2P',volts:208,amps:20,poles:2,bkw:4.16,ckw:3.33},
 {id:'208-30-2P',label:'208V 30A 2P',volts:208,amps:30,poles:2,bkw:6.24,ckw:4.99},
 {id:'208-60-2P',label:'208V 60A 2P',volts:208,amps:60,poles:2,bkw:12.48,ckw:9.98},
 {id:'208-20-3P',label:'208V 20A 3P',volts:208,amps:20,poles:3,bkw:7.20,ckw:5.76},
 {id:'208-30-3P',label:'208V 30A 3P',volts:208,amps:30,poles:3,bkw:10.80,ckw:8.64},
 {id:'208-60-3P',label:'208V 60A 3P',volts:208,amps:60,poles:3,bkw:21.59,ckw:17.27},
 {id:'240-20-1P',label:'240V 20A 1P',volts:240,amps:20,poles:1,bkw:4.80,ckw:3.84},
 {id:'240-30-1P',label:'240V 30A 1P',volts:240,amps:30,poles:1,bkw:7.20,ckw:5.76},
 {id:'240-60-1P',label:'240V 60A 1P',volts:240,amps:60,poles:1,bkw:14.40,ckw:11.52},
 {id:'415-20-2P',label:'415V 20A 2P',volts:415,amps:20,poles:2,bkw:8.30,ckw:6.64},
 {id:'415-30-2P',label:'415V 30A 2P',volts:415,amps:30,poles:2,bkw:12.45,ckw:9.96},
 {id:'415-60-2P',label:'415V 60A 2P',volts:415,amps:60,poles:2,bkw:24.90,ckw:19.92},
 {id:'415-20-3P',label:'415V 20A 3P',volts:415,amps:20,poles:3,bkw:14.38,ckw:11.50},
 {id:'415-30-3P',label:'415V 30A 3P',volts:415,amps:30,poles:3,bkw:21.56,ckw:17.25},
 {id:'415-60-3P',label:'415V 60A 3P',volts:415,amps:60,poles:3,bkw:43.13,ckw:34.50}
];
const PANEL_TYPES=[
 {id:'120-208-225A-42',label:'120/208V 225A 42-pole panel, 80%',volts:[120,208],amps:225,poles:42,derate:.8,capacityKw:64.86},
 {id:'120-208-225A-84',label:'120/208V 225A 84-pole panel, 80%',volts:[120,208],amps:225,poles:84,derate:.8,capacityKw:64.86},
 {id:'120-208-400A-42',label:'120/208V 400A 42-pole panel, 80%',volts:[120,208],amps:400,poles:42,derate:.8,capacityKw:115.26},
 {id:'120-208-400A-84',label:'120/208V 400A 84-pole panel, 80%',volts:[120,208],amps:400,poles:84,derate:.8,capacityKw:115.26},
 {id:'240-225A-42',label:'240V 225A 42-pole panel, 80%',volts:[240],amps:225,poles:42,derate:.8,capacityKw:86.4},
 {id:'240-400A-84',label:'240V 400A 84-pole panel, 80%',volts:[240],amps:400,poles:84,derate:.8,capacityKw:153.6},
 {id:'415-225A-42',label:'415V 225A 42-pole panel, 80%',volts:[415],amps:225,poles:42,derate:.8,capacityKw:129.38},
 {id:'415-400A-84',label:'415V 400A 84-pole panel, 80%',volts:[415],amps:400,poles:84,derate:.8,capacityKw:230.01}
];
const SOURCE_SETS={single:['A','B','C','D'],twoN:['A+B','A+C','A+D','B+C','B+D','C+D'],fourTo3:['A+B+C','A+B+D','A+C+D','B+C+D']};
let requests=[];let cabinetLibrary=[];let cabinetRowInfo={};let cabinetZoneInfo={};let rowRanges=[{row:"Row 1",zone:"Zone 1",start:"100",end:"199"}];let state={assignments:[],panelsBySource:{},checks:[],requiredPanelsBySource:{}};
function byId(id){return document.getElementById(id)};function val(id){return byId(id).value};function num(id){return parseFloat(val(id))||0};function esc(s){return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]))};
function getBranch(id){return BRANCH_CIRCUITS.find(x=>x.id===id)||BRANCH_CIRCUITS[0]}function getPanelType(){return PANEL_TYPES.find(x=>x.id===val('panelType'))||PANEL_TYPES[0]}
function panelCompatible(panel,branch){return panel.volts.includes(branch.volts)}
function sourceOptionsForDistribution(){let d=val('distribution');return d==='single'?SOURCE_SETS.single:d==='4to3'?SOURCE_SETS.fourTo3:SOURCE_SETS.twoN}
function syncDistribution(){const s=byId('sourceSet');const old=s.value;const opts=sourceOptionsForDistribution();s.innerHTML=opts.map(x=>`<option value="${x}">${x}</option>`).join('');s.value=opts.includes(old)?old:opts[0];}
function selectedSources(){return val('sourceSet').split('+')}
function requestSources(req){if(req.sourceOverride&&req.sourceOverride!=='auto')return req.sourceOverride.split('+');return selectedSources()}
function rowLabelForIndex(i){return 'Row '+(i+1);}
function zoneOptions(current){let zones=['Zone 1','Zone 2','Zone 3','Zone 4','Zone 5','Zone 6','Zone A','Zone B','Zone C','Zone D'];if(current&&!zones.includes(current))zones.unshift(current);return zones.map(z=>`<option value="${esc(z)}"${z===current?' selected':''}>${esc(z)}</option>`).join('');}
function rangeCabinets(startRaw,endRaw){let a=String(startRaw||'').trim(),b=String(endRaw||'').trim()||a;let m=a.match(/^(\d+)\s*-\s*(\d+)$/);if(m){a=m[1];b=m[2];}let start=Number(a),end=Number(b);if(!Number.isFinite(start))start=100;if(!Number.isFinite(end))end=start;if(end<start){let t=start;start=end;end=t;}let width=Math.max(a.length,b.length);let qty=Math.max(1,Math.min(500,end-start+1));return Array.from({length:qty},(_,i)=>String(start+i).padStart(width,'0'));}
function renderRowRanges(){const body=byId('rowRangeBody');if(!body)return;body.innerHTML=rowRanges.map((r,i)=>`<tr><td><input value="${esc(r.row)}" oninput="updateRowRange(${i},'row',this.value)"></td><td><select onchange="updateRowRange(${i},'zone',this.value)">${zoneOptions(r.zone||'Zone 1')}</select></td><td><input value="${esc(r.start)}" oninput="updateRowRange(${i},'start',this.value)"></td><td><input value="${esc(r.end)}" oninput="updateRowRange(${i},'end',this.value)"></td><td><button class="btn red" onclick="removeRowRange(${i})">Remove</button></td></tr>`).join('')||`<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:18px">No row ranges yet.</td></tr>`;}
function updateRowRange(i,k,v){rowRanges[i][k]=String(v).trim();renderRowRanges();}
function addRowRange(){let n=rowRanges.length+1;rowRanges.push({row:'Row '+n,zone:'Zone '+n,start:'',end:''});renderRowRanges();}
function removeRowRange(i){rowRanges.splice(i,1);renderRowRanges();}
function assignCabinetRows(){cabinetRowInfo={};cabinetZoneInfo={};cabinetLibrary.forEach((cab,i)=>{cabinetRowInfo[String(cab)]=cabinetRowInfo[String(cab)]||rowLabelForIndex(i);cabinetZoneInfo[String(cab)]=cabinetZoneInfo[String(cab)]||'Zone 1';});}
function generateCabinetsFromRanges(){cabinetLibrary=[];cabinetRowInfo={};cabinetZoneInfo={};rowRanges.forEach((r,idx)=>{rangeCabinets(r.start||'',r.end||r.start||'').forEach(cab=>{if(!cabinetLibrary.includes(cab)){cabinetLibrary.push(cab);cabinetRowInfo[cab]=r.row||rowLabelForIndex(idx);cabinetZoneInfo[cab]=r.zone||'Zone 1';}});});}
function rowForCabinet(cab){return cabinetRowInfo[String(cab)]||'';}
