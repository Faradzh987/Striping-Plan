function renderRequirements(){try{renderCabinetLibrary();}catch(e){console.error('Cabinet Library render failed:',e)}const body=byId('reqBody');let seen={};body.innerHTML=requests.map((r,i)=>{let cabKey=String(r.cab||'');let isChild=seen[cabKey];seen[cabKey]=true;let rowClass=isChild?'childCircuit':'parentCircuit';let cabCell=isChild?`<span class="indentIcon">↳</span><span class="qtyHint">Additional circuit for ${esc(cabKey)}</span>`:`<b>${esc(cabKey)}</b>`;return `<tr class="${rowClass}"><td><input value="${esc(r.row||rowForCabinet(r.cab))}" oninput="updateReq(${i},'row',this.value)"></td><td><select onchange="updateReq(${i},'zone',this.value)">${zoneOptions(r.zone||zoneForCabinet(r.cab))}</select></td><td class="cabCell">${isChild?cabCell:`<select onchange="updateReq(${i},'cab',this.value)">${cabinetSelectOptions(r.cab)}</select>`}</td><td><select onchange="updateReq(${i},'branch',this.value)">${branchOptions(r.branch)}</select></td><td><input type="number" min="1" value="${r.circuits}" oninput="updateReq(${i},'circuits',this.value)"></td><td><input type="number" min="0" step=".01" value="${r.kwEach}" oninput="updateReq(${i},'kwEach',this.value)"></td><td><select onchange="updateReq(${i},'sourceOverride',this.value)">${sourceOverrideOptions(r.sourceOverride||'auto')}</select></td><td><input value="${esc(r.pdu||'')}" oninput="updateReq(${i},'pdu',this.value)"></td><td><input value="${esc(r.notes||'')}" oninput="updateReq(${i},'notes',this.value)"></td><td><button type="button" class="btn smallbtn" onclick="addCircuitToCabinet(${i})">+ Circuit</button> <button type="button" class="btn red smallbtn" onclick="removeReq(${i})">Remove</button></td></tr>`}).join('')||`<tr><td colspan="10" style="text-align:center;color:var(--muted);padding:25px">No power requirements yet. Generate cabinets or add a requirement.</td></tr>`;}
function updateReq(i,k,v){const oldBranch=requests[i]?.branch;if(['qty','circuits','kwEach'].includes(k))v=Number(v)||0;if(k==='cab'&&requests[i]){requests[i].row=rowForCabinet(v)||requests[i].row||'';requests[i].zone=zoneForCabinet(v)||requests[i].zone||'Zone 1';}if(k==='branch'&&requests[i]){const oldDefault=oldBranch?branchDefaultKw(oldBranch):0;const curKw=Number(requests[i].kwEach)||0;if(!curKw||Math.abs(curKw-oldDefault)<.02){requests[i].kwEach=branchDefaultKw(v);}const b=getBranch(v);requests[i].pdu=`${Math.max(1,Math.round(Number(requests[i].circuits)||1))} x ${b.label}`;}requests[i][k]=v;renderCabinetLibrary();renderRequirements();calc();}
function removeReq(i){
  requests.splice(i,1);
  renderRequirements();
  renderCabinetLibrary();
  calc();
}
function expandRequirements(){const out=[];requests.forEach((r,ri)=>{if(!r.branch)return;let qty=Math.max(1,Math.round(Number(r.qty)||1));let circuits=Math.max(1,Math.round(Number(r.circuits)||1));for(let q=1;q<=qty;q++){let cab=qty>1?`${r.cab}-${q}`:r.cab;out.push({...r,row:r.row||rowForCabinet(r.cab)||'',zone:r.zone||zoneForCabinet(r.cab)||'Zone 1',cab,qty:1,circuitNo:1,circuits,kwEach:Number(r.kwEach)||0});}});return out;}
function circuitsForSource(item,sourceCount){return Math.max(1,Math.ceil((Number(item.circuits)||1)/Math.max(1,sourceCount)));}
function totalCustomerCircuits(){return requests.reduce((s,r)=>s+(r.branch?Math.max(1,Math.round(Number(r.qty)||1))*Math.max(1,Math.round(Number(r.circuits)||1)):0),0)}
function phasesFor(pos,poles){let n=(pos-1)%3;if(poles===3)return[0,1,2];if(poles===2)return[n,(n+1)%3];return[n];}
function emptyPanel(source,i,capacity){return {source,i,name:`${source}${i+1}`,used:0,usedPoles:0,kw:0,bkw:0,items:[],slots:{},capacity};}
function place(panel,item,branch,startPole){let circuit=startPole+panel.usedPoles;panel.used++;panel.usedPoles+=branch.poles;panel.kw+=item.kwEach;panel.bkw+=branch.bkw;let placed={...item,source:panel.source,panel:panel.i,panelName:panel.name,circuit,phases:phasesFor(circuit,branch.poles)};panel.items.push(placed);for(let x=0;x<branch.poles;x++)panel.slots[circuit+x]=placed;return placed;}
function choosePanel(panels,method,item,branch,cap){let fitsHard=p=>p.usedPoles+branch.poles<=p.capacity;let fitsIdeal=p=>fitsHard(p)&&p.kw+item.kwEach<=cap;let ideal=panels.filter(fitsIdeal);if(ideal.length){return ideal.sort((a,b)=>a.kw-b.kw||a.usedPoles-b.usedPoles)[0];}if(item.kwEach>cap){return panels.filter(fitsHard).sort((a,b)=>a.kw-b.kw||a.usedPoles-b.usedPoles)[0]||null;}return null;}
function calc(){syncCatalogInfo();const pt=getPanelType();const startPole=Math.max(1,Math.round(num('startPole')));const usable=Math.max(0,pt.poles-startPole+1);const items=expandRequirements();let sources=[...new Set(items.flatMap(requestSources))];const required={};
if(!items.length){state={assignments:[],panelsBySource:{},checks:buildChecks([],{},required,pt,usable),requiredPanelsBySource:required};renderAll();return;}
sources.forEach(s=>{let sourceItems=items.filter(it=>requestSources(it).includes(s));let slotsByBranch=0;let kw=0;sourceItems.forEach(it=>{let srcCount=requestSources(it).length;let perSourceCircuits=circuitsForSource(it,srcCount);slotsByBranch+=getBranch(it.branch).poles*perSourceCircuits;kw+=it.kwEach;});let panelsBySlots=Math.max(1,Math.ceil(slotsByBranch/usable));let panelsByKw=Math.max(1,Math.ceil(kw/pt.capacityKw));required[s]={panels:Math.max(panelsBySlots,panelsByKw),panelsBySlots,panelsByKw,kw,slotsByBranch};});
let panelsBySource={};sources.forEach(s=>panelsBySource[s]=Array.from({length:required[s].panels},(_,i)=>emptyPanel(s,i,usable)));
const assignments=[];items.forEach(it=>{let branch=getBranch(it.branch);let placements=[];let srcs=requestSources(it);let perSourceCircuits=circuitsForSource(it,srcs.length);srcs.forEach(s=>{for(let c=1;c<=perSourceCircuits;c++){let circuitItem={...it,circuitNo:c,circuits:perSourceCircuits,kwEach:it.kwEach/perSourceCircuits};let pList=panelsBySource[s]||(panelsBySource[s]=[emptyPanel(s,0,usable)]);pList.forEach(p=>p.capacity=usable);let p=choosePanel(pList,val('method'),circuitItem,branch,pt.capacityKw);if(!p){p=emptyPanel(s,pList.length,usable);pList.push(p);required[s]=required[s]||{panels:0,panelsBySlots:0,panelsByKw:0,kw:0,slotsByBranch:0};required[s].panels=pList.length;}placements.push(place(p,circuitItem,branch,startPole));}});assignments.push({...it,branchObj:branch,placements,phases:placements[0]?.phases||[]});});
state={assignments,panelsBySource,checks:buildChecks(assignments,panelsBySource,required,pt,usable),requiredPanelsBySource:required};renderAll();}
function buildChecks(assignments,panelsBySource,required,pt,usable){const checks=[];const licensed=num('licensedPower'),factor=num('opFactor')||1,allowed=licensed*factor;const uniqueLoad=uniqueKw();checks.push({level:uniqueLoad<=allowed?'good':'bad',title:'Licensed power and OP factor',msg:`Unique requested load is ${uniqueLoad.toFixed(1)} kW. Allowed provisioned power is ${allowed.toFixed(1)} kW (${licensed.toFixed(1)} kW × ${factor.toFixed(2)}).`});
const reqA=requestedContinuousAmpsByVoltage(), availA=availableContinuousAmpsByVoltage();Object.entries(reqA).forEach(([v,a])=>{let av=availA[v]||0;checks.push({level:a<=av?'good':'bad',title:`${v}V continuous amps`,msg:`Requested ${a.toFixed(0)}A continuous. Available from panel inventory ${av.toFixed(0)}A continuous.`});});requests.forEach((r,idx)=>{if(!r.branch)checks.push({level:'warn',title:`Cabinet ${r.cab||idx+1} missing circuit`,msg:'No circuit selected yet. This is a reminder, not a critical error.'});if((Number(r.circuits)||0)<=0)checks.push({level:'bad',title:`Cabinet ${r.cab||idx+1} circuit quantity`,msg:'Circuit quantity must be greater than zero.'});});assignments.forEach(a=>{let b=a.branchObj;if(!hasCompatibleInventoryPanel(b))checks.push({level:'bad',title:`No compatible panel: ${a.cab} row ${a.row}`,msg:`${b.label} requires a ${b.volts}V-compatible panel in Panel Inventory. Recommendation: add a ${b.volts}V panel to inventory or change the branch circuit. No email was sent to Erick.`});let maxCircuitKw=Math.max(0,...(a.placements||[]).map(p=>p.kwEach));if(maxCircuitKw>b.ckw)checks.push({level:'bad',title:`Circuit load exceeds maximum: ${a.cab} row ${a.row}`,msg:`${maxCircuitKw.toFixed(2)} kW per circuit exceeds the ${b.ckw.toFixed(2)} kW continuous limit for ${b.label}. Reduce expected draw or select a larger valid circuit.`});});
Object.entries(panelsBySource).forEach(([s,panels])=>panels.forEach(p=>{checks.push({level:p.kw<=pt.capacityKw?'good':'bad',title:`Panel ${p.name}`,msg:`${p.kw.toFixed(1)} kW expected of ${pt.capacityKw.toFixed(1)} kW panel capacity; ${p.used} circuits using ${p.usedPoles}/${p.capacity} pole positions.`});}));
Object.entries(required).forEach(([s,r])=>{let placedPanels=panelsBySource[s]||[];let placedCount=placedPanels.length||r.panels;let rawMinimum=Math.max(r.panelsBySlots,r.panelsByKw);let feeds=placedPanels.flatMap(p=>p.items||[]);let feedCount=feeds.length;let uniqueFeedKw=[...new Set(feeds.map(x=>Number(x.kwEach||0)).filter(x=>x>0).map(x=>x.toFixed(2)))].map(Number);let placementText='Actual mixed-feed placement';let placementPanels=placedCount;
if(uniqueFeedKw.length===1){let feedKw=uniqueFeedKw[0];let maxFeeds=Math.max(1,Math.floor(pt.capacityKw/feedKw));placementPanels=Math.ceil(feedCount/maxFeeds);placementText=`${maxFeeds} feeds max per panel; ${feedCount} feeds / ${maxFeeds}`;}
let reason=placedCount>rawMinimum?`Using only ${rawMinimum} panel(s) would overload at least one panel.`:'Capacity and placement fit within the same panel count.';
let msg=`<div class="sizing"><span>IT load</span><b>${r.kw.toFixed(1)} kW</b><span>Panel capacity</span><b>${pt.capacityKw.toFixed(1)} kW</b><span>Panels by total kW</span><b>${r.panelsByKw}</b><span>Panels by pole space</span><b>${r.panelsBySlots}</b><span>Panels by whole-feed placement</span><b>${placementPanels}</b><span>Final required</span><b>${placedCount}</b></div><p>${esc(reason)}</p>`;
checks.push({level:'good',title:`Source ${s} required panels`,msg,html:true});});
if(assignments.length===0)checks.push({level:'warn',title:'No power requirements entered',msg:'Add circuit rows when ready. Choosing panel inventory alone is not an error.'});return checks;}
function syncCatalogInfo(){const pt=getPanelType();const compat=BRANCH_CIRCUITS.filter(b=>panelCompatible(pt,b)).map(b=>b.label).join(', ');byId('catalogInfo').innerHTML=`<b>${esc(pt.label)}</b><br>Capacity: <b>${pt.capacityKw.toFixed(1)} kW</b> · ${pt.poles} poles · ${pt.amps}A · compatible branch voltages: ${pt.volts.join('/')}V<br><b>Allowed branch circuits on this panel:</b> ${esc(compat)}`;let allowed=num('licensedPower')*(num('opFactor')||1);byId('licenseInfo').innerHTML=`Allowed provisioned power: <b>${allowed.toFixed(1)} kW</b> = licensed power × OP factor.<br>Distribution redundancy is shown separately by source.`;}
function usedContinuousAmpsForPanel(p){return (p.items||[]).reduce((sum,it)=>sum+branchContinuousAmps(getBranch(it.branch)),0)}
function panelUsableAmps(pt){return pt.amps*pt.derate}
function engineeringRecommendations(){let rec=[];const pt=getPanelType();const avail=availableContinuousAmpsByVoltage();const req=requestedContinuousAmpsByVoltage();Object.entries(req).forEach(([v,a])=>{let av=avail[v]||0;if(a>av)rec.push(`Add ${(a-av).toFixed(0)}A usable ${v}V panel capacity or reduce ${v}V circuit quantity.`)});state.assignments.forEach(a=>{let b=a.branchObj;if(b&&!hasCompatibleInventoryPanel(b))rec.push(`Cabinet ${a.cab}: add a ${b.volts}V-compatible panel to Panel Inventory or change ${b.label} to a voltage that exists in inventory.`);});Object.values(state.panelsBySource).flat().forEach(p=>{let used=usedContinuousAmpsForPanel(p), cap=panelUsableAmps(pt), pct=cap?used/cap:0;if(pct>.9)rec.push(`Panel ${p.name}: ${used.toFixed(0)}A of ${cap.toFixed(0)}A usable (${(pct*100).toFixed(0)}%). Consider moving circuits or using a larger panel.`);});if(totalCustomerCircuits()===0)rec.push('Add branch circuits before generating a final panel schedule.');return [...new Set(rec)].slice(0,10);}
function renderEngineeringReview(){const box=byId('engineeringReview');if(!box)return;const bad=state.checks.filter(x=>x.level==='bad').length;const warn=state.checks.filter(x=>x.level==='warn').length;const recs=engineeringRecommendations();const reqA=requestedContinuousAmpsByVoltage();const availA=availableContinuousAmpsByVoltage();let ampRows=Object.keys({...reqA,...availA}).map(v=>`<li><b>${v}V amps:</b> requested ${(reqA[v]||0).toFixed(0)}A / available ${(availA[v]||0).toFixed(0)}A usable.</li>`).join('')||'<li>No circuits selected yet.</li>';box.innerHTML=`<h3>🔍 Engineering Review</h3><div class="mutedSmall">Amp-first sanity check for cabinet circuits, panel inventory, OP factor, and critical design issues.</div><ul>${ampRows}<li><b>Validation:</b> ${bad?bad+' critical issue(s)':warn?warn+' warning(s)':'OK'}.</li><li><b>OP factor:</b> ${uniqueKw().toFixed(1)} kW requested vs ${(num('licensedPower')*(num('opFactor')||1)).toFixed(1)} kW allowed.</li></ul><h4 style="margin:10px 0 4px">Recommendations</h4><ul>${recs.length?recs.map(r=>`<li>${esc(r)}</li>`).join(''):'<li>No major recommendations. Design looks reasonable based on current inputs.</li>'}</ul>`;}
function renderAll(){renderKpis();renderRequiredInfo();renderValidation();renderUtil();renderPhase();renderAssignments();renderMaps();renderPrintable();renderEngineeringReview();}
function uniqueKw(){return expandRequirements().reduce((s,it)=>s+it.kwEach,0)}
function sourceKwEntries(){return Object.entries(state.panelsBySource).map(([s,panels])=>[s,panels.reduce((sum,p)=>sum+p.kw,0)]).sort((a,b)=>a[0].localeCompare(b[0]));}
function renderKpis(){const pt=getPanelType();const bad=state.checks.filter(x=>x.level==='bad').length,warn=state.checks.filter(x=>x.level==='warn').length;const panels=Object.values(state.panelsBySource).flat();const worst=Math.max(0,...panels.map(p=>panelUsableAmps(pt)?usedContinuousAmpsForPanel(p)/panelUsableAmps(pt):0));let allowed=num('licensedPower')*(num('opFactor')||1);let layoutRows=new Set(requests.map(r=>r.row).filter(Boolean)).size;let totalA=Object.values(requestedContinuousAmpsByVoltage()).reduce((a,b)=>a+b,0);let base=[['Rows',layoutRows||0,''],['Cabinet rows',requests.length,''],['Branch circuits',totalCustomerCircuits(),''],['Requested amps',totalA.toFixed(0)+'A',''],['IT load',uniqueKw().toFixed(1)+' kW',uniqueKw()>allowed?'bad':'good']];let sourceCards=sourceKwEntries().map(([s,kw])=>[`Source ${s}`,kw.toFixed(1)+' kW','']);let tail=[['Panels total',panels.length,''],['Worst panel',(worst*100).toFixed(0)+'%',worst>1?'bad':worst>.9?'warn':'good'],['Validation',bad?bad+' critical':warn?warn+' warnings':'OK',bad?'bad':warn?'warn':'good']];byId('kpis').innerHTML=base.concat(sourceCards,tail).map(k=>`<div class="kpi"><div class="v ${k[2]||''}">${k[1]}</div><div class="l">${k[0]}</div></div>`).join('');}
function renderRequiredInfo(){const pt=getPanelType();const entries=Object.entries(state.requiredPanelsBySource).map(([s,r])=>`<span class="pill pV">Source ${s}: ${r.panels} × ${pt.amps}A panels</span>`).join(' ');let src=sourceKwEntries().map(([s,kw])=>`Source ${s}: ${kw.toFixed(1)} kW`).join(' · ');let redundant=sourceKwEntries().reduce((sum,[_s,kw])=>sum+kw,0);let facility=uniqueKw();byId('requiredInfo').innerHTML=`<b>Required Infrastructure</b><br><b>Panel amp inventory:</b> ${Object.entries(availableContinuousAmpsByVoltage()).map(([v,a])=>`${v}V ${a.toFixed(0)}A usable`).join(' · ')||'None'}<br><b>Requested amps:</b> ${Object.entries(requestedContinuousAmpsByVoltage()).map(([v,a])=>`${v}V ${a.toFixed(0)}A`).join(' · ')||'None'}<br>Distribution: <b>${esc(val('distribution'))}</b> · Source set: <b>${esc(val('sourceSet'))}</b> · Panel: <b>${esc(pt.label)}</b><br>${entries||'No source panels required yet.'}<br><b>Layout rows:</b> ${[...new Set(requests.map(r=>r.row).filter(Boolean))].join(', ')||'None'}<br><b>Zones:</b> ${[...new Set(requests.map(r=>r.zone).filter(Boolean))].join(', ')||'None'}<br><div class="engnote"><b>Engineering notes</b><br>Customer IT Load: <b>${uniqueKw().toFixed(1)} kW</b> · Provisioned redundant feed capacity: <b>${redundant.toFixed(1)} kW</b><br>${src}</div><br>Panel counts are based on actual cabinet/feed placement, not just total kW divided by panel capacity. Whole cabinet feeds cannot be split across panels.`;}
function renderValidation(){byId('validation').innerHTML=state.checks.map(ch=>`<div class="check ${ch.level==='good'?'':ch.level}"><h4>${ch.level==='good'?'✓':ch.level==='warn'?'⚠':'✕'} ${esc(ch.title)}</h4>${ch.html?ch.msg:`<p>${esc(ch.msg)}</p>`}</div>`).join('');}
function bar(label,pct,text,cls){return `<div class="barrow"><span>${label}</span><div class="bar"><div class="fill ${cls}" style="width:${Math.min(100,Math.max(0,pct))}%"></div></div><span>${text}</span></div>`}
function renderUtil(){const pt=getPanelType();const capA=panelUsableAmps(pt);const panels=Object.values(state.panelsBySource).flat();let avgA=panels.length?panels.reduce((s,p)=>s+usedContinuousAmpsForPanel(p),0)/panels.length:0;let maxA=Math.max(0,...panels.map(p=>usedContinuousAmpsForPanel(p))),minA=panels.length?Math.min(...panels.map(p=>usedContinuousAmpsForPanel(p))):0;let balance=panels.length&&avgA?((maxA-minA)/avgA*100):0;let cards=panels.map(p=>{let usedA=usedContinuousAmpsForPanel(p), remainingA=capA-usedA, pct=capA?usedA/capA*100:0,slot=p.capacity?p.usedPoles/p.capacity*100:0,kwPct=p.kw/pt.capacityKw*100,cls=pct>100?'red':pct>90?'amber':'green';return `<div class="util"><h3>Source ${p.source} ${p.name}<span class="pill ${pct>100?'pBad':pct>90?'pWarn':'pA'}">${pct.toFixed(0)}%</span></h3><div class="ampBig">${usedA.toFixed(0)}A / ${capA.toFixed(0)}A usable</div><div class="mutedSmall">Remaining: ${remainingA.toFixed(0)}A · Breaker: ${pt.amps}A @ ${(pt.derate*100).toFixed(0)}%</div>${bar('Amps',pct,`${usedA.toFixed(0)}A`,cls)}${bar('Expected kW',kwPct,`${p.kw.toFixed(1)} kW`,kwPct>100?'red':kwPct>85?'amber':'green')}${bar('Pole space',slot,`${p.usedPoles}/${p.capacity}`,'')}</div>`}).join('');let note=panels.length?`<div class="info engnote"><b>Amp utilization average:</b> ${avgA.toFixed(0)}A per panel · <b>Amp balance:</b> ${balance<=25?'Excellent':balance<=50?'Good':'Review'} (${balance.toFixed(0)}% spread vs average). kW remains available as secondary context only.</div>`:'';byId('utilCards').innerHTML=cards||'<p class="hint">No panels generated.</p>'; if(byId('utilNote')) byId('utilNote').innerHTML=note;}
function phaseTotals(){let ph=[0,0,0],cnt=[0,0,0];state.assignments.forEach(a=>a.placements.forEach(pl=>{let b=getBranch(pl.branch);let amps=branchContinuousAmps(b);pl.phases.forEach(p=>{ph[p]+=amps;cnt[p]++})}));return {ph,cnt};}
function renderPhase(){const {ph,cnt}=phaseTotals();let max=Math.max(...ph),min=Math.min(...ph),avg=(ph[0]+ph[1]+ph[2])/3,imb=avg?((max-min)/avg*100):0;byId('phaseCards').innerHTML=['A','B','C'].map((x,i)=>`<div class="phase"><div class="pv">${ph[i].toFixed(0)}A</div><div class="pl">Phase ${x} · ${cnt[i]} legs</div></div>`).join('');byId('phaseNote').innerHTML=`Phase imbalance: <b class="${imb>5?'bad':imb>2?'warn':'good'}">${imb.toFixed(1)}%</b> max-min vs average continuous amps. Mixed 1P/2P loads can create imbalance; review striping when above target.`;}
function renderAssignments(){byId('assignBody').innerHTML=state.assignments.map(a=>{let b=a.branchObj;let status=[];if(!hasCompatibleInventoryPanel(b))status.push('<span class="pill pBad">No compatible panel</span>');if(a.kwEach>b.ckw)status.push('<span class="pill pBad">Over max cKW</span>');if(!status.length)status.push('<span class="pill pA">OK</span>');let places=a.placements.map(p=>`<span class="pill pB">${p.source} ${p.panelName} C${p.circuit}</span>`).join('');let phases=[...new Set(a.placements.flatMap(p=>p.phases))].map(p=>'ABC'[p]).join('-');return `<tr><td><b>${esc(a.cab)}</b></td><td>Row ${a.row} · ${a.circuitNo}/${a.circuits}</td><td>${esc(b.label)} · ${branchContinuousAmps(b).toFixed(0)}A usable</td><td>${a.kwEach.toFixed(2)} kW</td><td>${places}</td><td>${phases}</td><td>${status.join('')}</td></tr>`}).join('')||'<tr><td colspan="7">No assignments.</td></tr>';}
function renderMaps(){const pt=getPanelType();const start=Math.max(1,Math.round(num('startPole')));const container=byId('mapsBySource');container.innerHTML=Object.entries(state.panelsBySource).map(([source,panels])=>`<h3>Source ${source} Panels</h3><div class="maps">${panels.map(p=>renderMap(p,pt,start)).join('')}</div>`).join('')||'<p class="hint">No maps generated.</p>';}
function renderMap(p,pt,start){let html=`<div class="map"><div class="maphead"><span>${p.name}</span><span>${usedContinuousAmpsForPanel(p).toFixed(0)}A · ${p.usedPoles}/${p.capacity} poles</span></div><div class="rpp"><div class="colhdr">Odd</div><div class="colhdr">Even</div>`;for(let pos=start;pos<=pt.poles;pos+=2){[pos,pos+1].forEach(s=>{if(s>pt.poles){html+='<div></div>';return}let item=p.slots[s];let b=item?getBranch(item.branch):null;html+=item?`<div class="slot used"><div class="slotno">#${s} · ${b.poles}P · ${esc(b.label)}</div><div class="slotcab">${esc(item.cab)} · ${esc(item.row||'')} · ${esc(item.zone||'')}.${item.circuitNo}</div><div class="slotkw">${item.kwEach.toFixed(1)} kW · Ph ${item.phases.map(x=>'ABC'[x]).join('-')}</div></div>`:`<div class="slot"><div class="slotno">#${s} available</div></div>`})}return html+'</div></div>';}
function renderPrintable(){byId('printOut').innerHTML=`<h1>Opportunity Room Power Summary</h1><p><b>Customer:</b> ${esc(val('customer'))} &nbsp; <b>Opportunity:</b> ${esc(val('oppty'))} &nbsp; <b>Site:</b> ${esc(val('site'))}</p><p><b>Engineer:</b> ${esc(val('engineer'))} &nbsp; <b>Date:</b> ${esc(val('date'))} &nbsp; <b>CIM/Quote:</b> ${esc(val('ticket'))}</p><p><b>Licensed Power:</b> ${num('licensedPower').toFixed(1)} kW &nbsp; <b>OP Factor:</b> ${(num('opFactor')||1).toFixed(2)}  &nbsp; <b>Distribution:</b> ${esc(val('distribution'))} ${esc(val('sourceSet'))}</p><h2>Required Infrastructure</h2><div class="info">${byId('requiredInfo').innerHTML}</div><h2>Validation</h2><div class="validation">${byId('validation').innerHTML}</div><h2>Panel Utilization</h2><div class="cards">${byId('utilCards').innerHTML}</div>${byId('utilNote')?byId('utilNote').innerHTML:''}<h2>Panel Maps</h2>${byId('mapsBySource').innerHTML}`;}
function showView(id,btn){document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));byId('view-'+id).classList.add('active');document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active');}
function toggleTheme(){let t=document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark';document.documentElement.setAttribute('data-theme',t);localStorage.setItem('orc-theme',t);byId('themeBtn').textContent=t==='dark'?'Light mode':'Dark mode'}
function saveProject(){const data={project:['customer','oppty','site','engineer','date','ticket','notes','licensedPower','opFactor','distribution','sourceSet','panelType','startPole','method'].reduce((o,id)=>(byId(id)?o[id]=val(id):null,o),{}),requests,cabinetLibrary,cabinetRowInfo,cabinetZoneInfo,rowRanges,panelInventory};download('opportunity-room-project.json',JSON.stringify(data,null,2),'application/json');}
function loadProject(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=()=>{let d=JSON.parse(r.result);Object.entries(d.project||{}).forEach(([k,v])=>{if(byId(k))byId(k).value=v});syncDistribution();Object.entries(d.project||{}).forEach(([k,v])=>{if(byId(k))byId(k).value=v});rowRanges=d.rowRanges||rowRanges;panelInventory=d.panelInventory||panelInventory;renderRowRanges();renderPanelInventory();cabinetLibrary=d.cabinetLibrary||cabinetLibrary||[];cabinetRowInfo=d.cabinetRowInfo||{};cabinetZoneInfo=d.cabinetZoneInfo||{};if(!Object.keys(cabinetRowInfo).length)assignCabinetRows();requests=(d.requests||d.cabinets||[]).map(r=>({...r,row:r.row||rowForCabinet(r.cab),zone:r.zone||zoneForCabinet(r.cab)}));renderCabinetLibrary();renderRequirements();calc()};r.readAsText(f);}
function xlEsc(s){return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&apos;'}[m]));}
function xlStripHtml(s){let d=document.createElement('div');d.innerHTML=String(s??'');return d.textContent||d.innerText||'';}
function xlCell(value,style,type){let v=value??'';let t=type||(typeof v==='number'&&Number.isFinite(v)?'Number':'String');let attrs=style?` ss:StyleID="${style}"`:'';return `<Cell${attrs}><Data ss:Type="${t}">${xlEsc(v)}</Data></Cell>`;}
function xlRow(cells,style){return `<Row>${cells.map(c=>Array.isArray(c)?xlCell(c[0],c[1]||style,c[2]):xlCell(c,style)).join('')}</Row>`;}
function xlBlank(n=1){return Array.from({length:n},()=>'<Row/>').join('');}
function xlSheet(name,widths,rows){let cols=(widths||[]).map(w=>`<Column ss:Width="${w}"/>`).join('');return `<Worksheet ss:Name="${xlEsc(name).slice(0,31)}"><Table>${cols}${rows.join('')}</Table><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><FreezePanes/><FrozenNoSplit/><SplitHorizontal>1</SplitHorizontal><TopRowBottomPane>1</TopRowBottomPane><ProtectObjects>False</ProtectObjects><ProtectScenarios>False</ProtectScenarios></WorksheetOptions><AutoFilter x:Range="R1C1:R1C12" xmlns="urn:schemas-microsoft-com:office:excel"/></Worksheet>`;}
function exportExcel(){
 calc();
 const pt=getPanelType();
 const panels=Object.values(state.panelsBySource||{}).flat();
 const bad=(state.checks||[]).filter(x=>x.level==='bad').length;
 const warn=(state.checks||[]).filter(x=>x.level==='warn').length;
 const validationStatus=bad?`FAIL - ${bad} critical`:warn?`REVIEW - ${warn} warning(s)`:'PASS';
 const reqA=requestedContinuousAmpsByVoltage();
 const availA=availableContinuousAmpsByVoltage();
 const sourceKw=sourceKwEntries();
 const inv=panelInvRows();
 const styles=`<Styles>
  <Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Center"/><Font ss:FontName="Calibri" ss:Size="11"/><Interior/><NumberFormat/><Protection/></Style>
  <Style ss:ID="Title"><Font ss:FontName="Calibri" ss:Size="18" ss:Bold="1" ss:Color="#FFFFFF"/><Interior ss:Color="#1F4E78" ss:Pattern="Solid"/><Alignment ss:Horizontal="Center" ss:Vertical="Center"/></Style>
  <Style ss:ID="SubTitle"><Font ss:FontName="Calibri" ss:Size="12" ss:Bold="1" ss:Color="#1F4E78"/><Interior ss:Color="#D9EAF7" ss:Pattern="Solid"/></Style>
  <Style ss:ID="Header"><Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1" ss:Color="#FFFFFF"/><Interior ss:Color="#305496" ss:Pattern="Solid"/><Alignment ss:Horizontal="Center"/><Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#FFFFFF"/></Borders></Style>
  <Style ss:ID="Label"><Font ss:FontName="Calibri" ss:Size="11" ss:Bold="1" ss:Color="#1F4E78"/><Interior ss:Color="#EAF2F8" ss:Pattern="Solid"/><Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#D9E2F3"/></Borders></Style>
  <Style ss:ID="Text"><Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E7E6E6"/></Borders></Style>
  <Style ss:ID="Number"><NumberFormat ss:Format="0.0"/><Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E7E6E6"/></Borders></Style>
  <Style ss:ID="Integer"><NumberFormat ss:Format="0"/><Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#E7E6E6"/></Borders></Style>
  <Style ss:ID="OK"><Font ss:Bold="1" ss:Color="#006100"/><Interior ss:Color="#C6EFCE" ss:Pattern="Solid"/></Style>
  <Style ss:ID="Warn"><Font ss:Bold="1" ss:Color="#9C6500"/><Interior ss:Color="#FFEB9C" ss:Pattern="Solid"/></Style>
  <Style ss:ID="Bad"><Font ss:Bold="1" ss:Color="#9C0006"/><Interior ss:Color="#FFC7CE" ss:Pattern="Solid"/></Style>
 </Styles>`;
 const now=new Date().toLocaleString();
 const summaryRows=[];
 summaryRows.push(xlRow([[`Opportunity Room Power Calculator Export`,'Title']],null));
 summaryRows.push(xlBlank());
 summaryRows.push(xlRow([['Project','SubTitle']]));
 [['Customer',val('customer')],['Opportunity',val('oppty')],['Site',val('site')],['Engineer',val('engineer')],['Date',val('date')],['CIM / Quote',val('ticket')],['Exported',now]].forEach(r=>summaryRows.push(xlRow([[r[0],'Label'],[r[1],'Text']])));
 summaryRows.push(xlBlank());
 summaryRows.push(xlRow([['Design Summary','SubTitle']]));
 [['Licensed Power kW',num('licensedPower'),'Number'],['OP Factor',num('opFactor')||1,'Number'],['Requested IT Load kW',uniqueKw(),'Number'],['Allowed Provisioned Power kW',num('licensedPower')*(num('opFactor')||1),'Number'],['Distribution',val('distribution'),'Text'],['Source Set',val('sourceSet'),'Text'],['Active Panel Type',pt.label,'Text'],['Panels Generated',panels.length,'Integer'],['Validation Status',validationStatus,bad?'Bad':warn?'Warn':'OK']].forEach(r=>summaryRows.push(xlRow([[r[0],'Label'],[r[1],r[2],r[2]==='Number'||r[2]==='Integer'?'Number':'String']])));
 summaryRows.push(xlBlank());
 summaryRows.push(xlRow([['Amp Summary','SubTitle']]));
 summaryRows.push(xlRow([['Voltage','Header'],['Requested Continuous A','Header'],['Available Continuous A','Header'],['Remaining A','Header'],['Status','Header']]));
 [...new Set([...Object.keys(reqA),...Object.keys(availA)])].sort((a,b)=>Number(a)-Number(b)).forEach(v=>{let req=reqA[v]||0,av=availA[v]||0,rem=av-req;summaryRows.push(xlRow([[v+'V','Text'],[req,'Number','Number'],[av,'Number','Number'],[rem,'Number','Number'],[rem>=0?'OK':'OVER CAPACITY',rem>=0?'OK':'Bad']]));});
 summaryRows.push(xlBlank());
 summaryRows.push(xlRow([['Source Loads','SubTitle']]));
 summaryRows.push(xlRow([['Source','Header'],['Load kW','Header']]));
 sourceKw.forEach(([s,kw])=>summaryRows.push(xlRow([[s,'Text'],[kw,'Number','Number']])));
 const inventoryRows=[xlRow([['Panel Inventory','Title']]),xlBlank(),xlRow([['Panel Type','Header'],['Voltage(s)','Header'],['Breaker A','Header'],['Usable A Each','Header'],['Qty','Header'],['Total Usable A','Header'],['Pole Count','Header'],['Capacity kW Each','Header']])];
 inv.forEach(r=>inventoryRows.push(xlRow([[r.type.label,'Text'],[r.type.volts.join('/'),'Text'],[r.type.amps,'Integer','Number'],[r.type.amps*r.type.derate,'Number','Number'],[r.qty,'Integer','Number'],[r.type.amps*r.type.derate*r.qty,'Number','Number'],[r.type.poles,'Integer','Number'],[r.type.capacityKw,'Number','Number']])));
 const cabRows=[xlRow([['Cabinet Schedule','Title']]),xlBlank(),xlRow([['Row','Header'],['Zone','Header'],['Cabinet','Header'],['Branch Circuit','Header'],['Voltage','Header'],['Breaker A','Header'],['Usable A Each','Header'],['Circuit Qty','Header'],['Total Usable A','Header'],['Expected kW Each','Header'],['Source Override','Header'],['PDU / Requirement','Header'],['Notes','Header']])];
 requests.forEach(r=>{let b=r.branch?getBranch(r.branch):null;let qty=Math.max(0,Math.round(Number(r.circuits)||0));cabRows.push(xlRow([[r.row||rowForCabinet(r.cab),'Text'],[r.zone||zoneForCabinet(r.cab),'Text'],[r.cab,'Text'],[b?b.label:'','Text'],[b?b.volts:'','Integer','Number'],[b?b.amps:'','Integer','Number'],[b?branchContinuousAmps(b):'','Number','Number'],[qty,'Integer','Number'],[b?branchContinuousAmps(b)*qty:0,'Number','Number'],[Number(r.kwEach)||0,'Number','Number'],[r.sourceOverride||'auto','Text'],[r.pdu||'','Text'],[r.notes||'','Text']]));});
 const panelRows=[xlRow([['Panel Schedule','Title']]),xlBlank(),xlRow([['Source','Header'],['Panel','Header'],['Circuit Position','Header'],['Cabinet','Header'],['Row','Header'],['Zone','Header'],['Branch Circuit','Header'],['Phase(s)','Header'],['Load kW','Header'],['Breaker A','Header'],['Usable A','Header'],['Poles','Header']])];
 Object.entries(state.panelsBySource||{}).forEach(([source,plist])=>plist.forEach(p=>{(p.items||[]).forEach(item=>{let b=getBranch(item.branch);panelRows.push(xlRow([[source,'Text'],[p.name,'Text'],[item.circuit,'Integer','Number'],[item.cab,'Text'],[item.row||'','Text'],[item.zone||'','Text'],[b.label,'Text'],[(item.phases||[]).map(x=>'ABC'[x]).join('-'),'Text'],[Number(item.kwEach)||0,'Number','Number'],[b.amps,'Integer','Number'],[branchContinuousAmps(b),'Number','Number'],[b.poles,'Integer','Number']]));});}));
 const valRows=[xlRow([['Validation Report','Title']]),xlBlank(),xlRow([['Status','Header'],['Check','Header'],['Details','Header'],['Recommendation','Header']])];
 (state.checks||[]).forEach(ch=>{let status=ch.level==='good'?'PASS':ch.level==='warn'?'REVIEW':'CRITICAL';let style=ch.level==='good'?'OK':ch.level==='warn'?'Warn':'Bad';let msg=ch.html?xlStripHtml(ch.msg):String(ch.msg||'');let rec='';if(status==='CRITICAL'&&/Voltage mismatch|compatible/i.test(ch.title+' '+msg))rec='Select a compatible branch circuit or add a matching voltage panel to inventory.';else if(status==='CRITICAL'&&/amp|capacity|Panel/i.test(ch.title+' '+msg))rec='Reduce circuit quantity/load or add panel capacity.';else if(status==='REVIEW')rec='Review before final design package.';valRows.push(xlRow([[status,style],[ch.title,'Text'],[msg,'Text'],[rec,'Text']]));});
 const workbook=`<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet" xmlns:html="http://www.w3.org/TR/REC-html40"><DocumentProperties xmlns="urn:schemas-microsoft-com:office:office"><Author>${xlEsc(val('engineer')||'CoreSite')}</Author><Title>Opportunity Room Power Calculator Export</Title><Created>${new Date().toISOString()}</Created></DocumentProperties>${styles}${xlSheet('Executive Summary',[180,220,120,120,120],summaryRows)}${xlSheet('Panel Inventory',[340,90,80,100,60,110,80,110],inventoryRows)}${xlSheet('Cabinet Schedule',[100,100,120,180,80,80,100,90,110,110,120,200,220],cabRows)}${xlSheet('Panel Schedule',[80,90,100,120,100,100,180,90,90,80,80,60],panelRows)}${xlSheet('Validation Report',[90,240,520,300],valRows)}</Workbook>`;
 download('opportunity-room-professional-export.xls',workbook,'application/vnd.ms-excel');
}
function download(name,text,type){let blob=new Blob([text],{type});let a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;a.click();setTimeout(()=>URL.revokeObjectURL(a.href),500);}
function importCsvPrompt(){let txt=prompt('Paste CSV rows: Row,Zone,Cabinet,Qty,Branch ID,Circuit Qty,Expected kW Each,Source Override,PDU,Notes');if(!txt)return;txt.split(/\n+/).forEach(line=>{let parts=line.split(',');let row,zone,cab,qty,branch,circuits,kwEach,sourceOverride,pdu,notes;if(parts.length>=10){[row,zone,cab,qty,branch,circuits,kwEach,sourceOverride,pdu,notes]=parts;}else if(parts.length>=9){[row,cab,qty,branch,circuits,kwEach,sourceOverride,pdu,notes]=parts;zone=zoneForCabinet(cab);}else{[cab,qty,branch,circuits,kwEach,sourceOverride,pdu,notes]=parts;row=rowForCabinet(cab);zone=zoneForCabinet(cab);}if(cab)requests.push({row:(row||rowForCabinet(cab)||'').trim(),zone:(zone||zoneForCabinet(cab)||'Zone 1').trim(),cab:cab.trim(),qty:Number(qty)||1,branch:(branch||'208-60-3P').trim(),circuits:Number(circuits)||1,kwEach:Number(kwEach)||0,sourceOverride:(sourceOverride||'auto').trim(),pdu:pdu||'',notes:notes||''})});renderRequirements();calc();}
