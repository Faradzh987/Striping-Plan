function init(){byId('date').valueAsDate=new Date();byId('panelType').innerHTML=PANEL_TYPES.map(x=>`<option value="${x.id}">${x.label}</option>`).join('');byId('panelType').value='120-208-225A-42';if(byId('bulkBranch')){byId('bulkBranch').innerHTML=branchOptions('208-60-3P');byId('bulkBranch').value='208-60-3P';}syncDistribution();renderRowRanges();resetCabinetLibrary(false);requests=[];renderRequirements();calc();}
function blankRequirement(cab){return {row:rowForCabinet(cab),zone:zoneForCabinet(cab),cab:String(cab),qty:1,branch:'',circuits:1,kwEach:'',pdu:'',notes:'',sourceOverride:'auto'};}
