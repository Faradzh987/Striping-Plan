function addBulkCabinetsFromText(){
  const input=prompt('Add cabinet(s): examples 101, 101,10, or 0101-0110');
  if(!input)return;
  const raw=String(input).trim();
  let start=raw, qty='', end='';
  if(raw.includes(',')){
    const parts=raw.split(',').map(x=>x.trim());
    start=parts[0]||''; qty=parts[1]||'';
  }else if(raw.includes('-')){
    const parts=raw.split('-').map(x=>x.trim());
    start=parts[0]||''; end=parts[1]||'';
  }
  const cabinets=rangeCabinets(start,end,qty);
  const defaultRow=rowLabelForIndex(cabinetLibrary.length);
  const row=prompt('Row for these cabinet(s)', defaultRow)||defaultRow;
  const zone=prompt('Zone for these cabinet(s)', 'Zone 1')||'Zone 1';
  cabinets.forEach(name=>{
    if(name&&!cabinetLibrary.includes(name)){
      cabinetLibrary.push(name);
      cabinetRowInfo[name]=row;
      cabinetZoneInfo[name]=zone;
      if(!requests.some(r=>String(r.cab)===name))requests.push(blankRequirement(name));
    }
  });
  renderCabinetLibrary();renderRequirements();calc();
}
