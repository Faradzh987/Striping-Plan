function generateCabinetLibrary(){generateCabinetsFromRanges();syncRequirementsToCabinets();renderCabinetLibrary();renderRequirements();calc();}
function addLibraryCabinet(){const next=prompt('Cabinet number/name to add');if(!next)return;const name=String(next).trim();if(name&&!cabinetLibrary.includes(name)){cabinetLibrary.push(name);cabinetRowInfo[name]=prompt('Row for '+name, rowLabelForIndex(cabinetLibrary.length-1))||rowLabelForIndex(cabinetLibrary.length-1);cabinetZoneInfo[name]=prompt('Zone for '+name, 'Zone 1')||'Zone 1';if(!requests.some(r=>String(r.cab)===name))requests.push(blankRequirement(name));}renderCabinetLibrary();renderRequirements();calc();}
function removeLibraryCabinet(i){const name=cabinetLibrary[i];if(requests.some(r=>String(r.cab)===String(name))&&!confirm(`${name} also has a Power Requirements row. Remove both?`))return;cabinetLibrary.splice(i,1);requests=requests.filter(r=>String(r.cab)!==String(name));renderCabinetLibrary();renderRequirements();calc();}
function usedCabinetNames(){return new Set(requests.map(r=>String(r.cab)).filter(Boolean));}
function renderCabinetLibrary(){const body=byId('cabLibBody');const used=usedCabinetNames();body.innerHTML=cabinetLibrary.map((name,i)=>`<tr><td><input value="${esc(rowForCabinet(name))}" oninput="updateLibraryRow(${i},this.value)"></td><td><select onchange="updateLibraryZone(${i},this.value)">${zoneOptions(zoneForCabinet(name))}</select></td><td><input value="${esc(name)}" oninput="updateLibraryCabinet(${i},this.value)"></td><td>${used.has(String(name))?'<span class="pill pA">Used</span>':'<span class="pill pB">Available</span>'}</td><td><button class="btn red" onclick="removeLibraryCabinet(${i})">Remove</button></td></tr>`).join('')||`<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:25px">No cabinets in library.</td></tr>`;}
function updateLibraryCabinet(i,v){const oldName=String(cabinetLibrary[i]||'');const newName=String(v).trim();const oldRow=cabinetRowInfo[oldName]||rowLabelForIndex(i);const oldZone=cabinetZoneInfo[oldName]||'Zone 1';cabinetLibrary[i]=newName;delete cabinetRowInfo[oldName];delete cabinetZoneInfo[oldName];cabinetRowInfo[newName]=oldRow;cabinetZoneInfo[newName]=oldZone;requests.forEach(r=>{if(String(r.cab)===oldName){r.cab=newName;r.row=oldRow;r.zone=oldZone;}});renderRequirements();calc();}
function updateLibraryRow(i,v){const name=String(cabinetLibrary[i]||'');cabinetRowInfo[name]=String(v).trim();requests.forEach(r=>{if(String(r.cab)===name)r.row=cabinetRowInfo[name];});renderRequirements();calc();}
function updateLibraryZone(i,v){const name=String(cabinetLibrary[i]||'');cabinetZoneInfo[name]=String(v).trim();requests.forEach(r=>{if(String(r.cab)===name)r.zone=cabinetZoneInfo[name];});renderRequirements();calc();}
function cabinetSelectOptions(current){const currentStr=String(current||'');const used=usedCabinetNames();let options=[...cabinetLibrary];if(currentStr&&!options.includes(currentStr))options.unshift(currentStr);return options.map(name=>{const disabled=used.has(String(name))&&String(name)!==currentStr?' disabled':'';const selected=String(name)===currentStr?' selected':'';const label=disabled?`${name} (used)`:name;return `<option value="${esc(name)}"${selected}${disabled}>${esc(label)}</option>`;}).join('');}
function branchOptions(current){return `<option value=""${!current?' selected':''}>Select circuit</option>`+BRANCH_CIRCUITS.map(b=>`<option value="${b.id}"${b.id===current?' selected':''}>${b.label}</option>`).join('')}
function sourceOverrideOptions(current){let opts=['auto','A','B','C','D','A+B','A+C','A+D','B+C','B+D','C+D','A+B+C','A+B+D','A+C+D','B+C+D'];return opts.map(o=>`<option value="${o}"${o===current?' selected':''}>${o==='auto'?'Auto from distribution':o}</option>`).join('')}
function seedMixedExample(){requests=[
 {row:rowForCabinet('101'),zone:zoneForCabinet('101'),cab:'101',qty:1,branch:'208-60-3P',circuits:2,kwEach:17,pdu:'Two 60A 3P',notes:'Mixed example',sourceOverride:'auto'},
 {row:rowForCabinet('102'),zone:zoneForCabinet('102'),cab:'102',qty:1,branch:'208-20-2P',circuits:2,kwEach:3.2,pdu:'Two 20A 2P',notes:'',sourceOverride:'auto'},
 {row:rowForCabinet('103'),zone:zoneForCabinet('103'),cab:'103',qty:1,branch:'120-20-1P',circuits:1,kwEach:1.2,pdu:'One 20A 1P',notes:'',sourceOverride:'auto'}
];renderRequirements();calc();}
function applyBulkRequirements(){const branch=val('bulkBranch')||'208-60-3P';const circuits=Math.max(0,Math.round(Number(val('bulkCircuits'))||0));const kwEach=Number(val('bulkKwEach'))||0;const b=getBranch(branch);const defaultPdu=`${circuits} x ${b.label}`;if(!requests.length)syncRequirementsToCabinets();requests=requests.map(r=>({...r,qty:1,branch,circuits,kwEach,pdu:defaultPdu,sourceOverride:r.sourceOverride||'auto'}));renderRequirements();calc();}
function addRequest(row){if(!row){const used=usedCabinetNames();row=blankRequirement(cabinetLibrary.find(x=>!used.has(String(x)))||cabinetLibrary[0]||'CAB');}requests.push(row);renderRequirements();calc();}
function duplicateLast(){if(requests.length)addRequest({...requests[requests.length-1],cab:requests[requests.length-1].cab+' copy'});else addRequest();}
function clearRequirements(){if(confirm('Clear all power requirement rows?')){requests=[];renderRequirements();calc();}}
function renderRequirements(){renderCabinetLibrary();const body=byId('reqBody');body.innerHTML=requests.map((r,i)=>`<tr><td><input value="${esc(r.row||rowForCabinet(r.cab))}" oninput="updateReq(${i},'row',this.value)"></td><td><select onchange="updateReq(${i},'zone',this.value)">${zoneOptions(r.zone||zoneForCabinet(r.cab))}</select></td><td><select onchange="updateReq(${i},'cab',this.value)">${cabinetSelectOptions(r.cab)}</select></td><td><input type="number" min="1" value="${r.qty}" oninput="updateReq(${i},'qty',this.value)"></td><td><select onchange="updateReq(${i},'branch',this.value)">${branchOptions(r.branch)}</select></td><td><input type="number" min="1" value="${r.circuits}" oninput="updateReq(${i},'circuits',this.value)"></td><td><input type="number" min="0" step=".1" value="${r.kwEach}" oninput="updateReq(${i},'kwEach',this.value)"></td><td><select onchange="updateReq(${i},'sourceOverride',this.value)">${sourceOverrideOptions(r.sourceOverride||'auto')}</select></td><td><input value="${esc(r.pdu||'')}" oninput="updateReq(${i},'pdu',this.value)"></td><td><input value="${esc(r.notes||'')}" oninput="updateReq(${i},'notes',this.value)"></td><td><button class="btn red" onclick="removeReq(${i})">Remove</button></td></tr>`).join('')||`<tr><td colspan="11" style="text-align:center;color:var(--muted);padding:25px">No power requirements yet. Generate cabinets or add a requirement.</td></tr>`;}
function updateReq(i,k,v){if(['qty','circuits','kwEach'].includes(k))v=Number(v)||0;if(k==='cab'&&requests[i]){requests[i].row=rowForCabinet(v)||requests[i].row||'';requests[i].zone=zoneForCabinet(v)||requests[i].zone||'Zone 1';}requests[i][k]=v;renderCabinetLibrary();calc();}
function removeReq(i){requests.splice(i,1);renderRequirements();calc();}
function expandRequirements(){const out=[];requests.forEach((r,ri)=>{if(!r.branch)return;let qty=Math.max(1,Math.round(Number(r.qty)||1));let circuits=Math.max(1,Math.round(Number(r.circuits)||1));for(let q=1;q<=qty;q++){let cab=qty>1?`${r.cab}-${q}`:r.cab;out.push({...r,row:r.row||rowForCabinet(r.cab)||'',zone:r.zone||zoneForCabinet(r.cab)||'Zone 1',cab,qty:1,circuitNo:1,circuits,kwEach:Number(r.kwEach)||0});}});return out;}
function circuitsForSource(item,sourceCount){return Math.max(1,Math.ceil((Number(item.circuits)||1)/Math.max(1,sourceCount)));}
function totalCustomerCircuits(){return requests.reduce((s,r)=>s+(r.branch?Math.max(1,Math.round(Number(r.qty)||1))*Math.max(1,Math.round(Number(r.circuits)||1)):0),0)}
function phasesFor(pos,poles){let n=(pos-1)%3;if(poles===3)return[0,1,2];if(poles===2)return[n,(n+1)%3];return[n];}
function emptyPanel(source,i,capacity){return {source,i,name:`${source}${i+1}`,used:0,usedPoles:0,kw:0,bkw:0,items:[],slots:{},capacity};}
function place(panel,item,branch,startPole){let circuit=startPole+panel.usedPoles;panel.used++;panel.usedPoles+=branch.poles;panel.kw+=item.kwEach;panel.bkw+=branch.bkw;let placed={...item,source:panel.source,panel:panel.i,panelName:panel.name,circuit,phases:phasesFor(circuit,branch.poles)};panel.items.push(placed);for(let x=0;x<branch.poles;x++)panel.slots[circuit+x]=placed;return placed;}
function choosePanel(panels,method,item,branch,cap){let fitsHard=p=>p.usedPoles+branch.poles<=p.capacity;let fitsIdeal=p=>fitsHard(p)&&p.kw+item.kwEach<=cap;let ideal=panels.filter(fitsIdeal);if(ideal.length){return ideal.sort((a,b)=>a.kw-b.kw||a.usedPoles-b.usedPoles)[0];}if(item.kwEach>cap){return panels.filter(fitsHard).sort((a,b)=>a.kw-b.kw||a.usedPoles-b.usedPoles)[0]||null;}return null;}
function calc(){syncCatalogInfo();const pt=getPanelType();const startPole=Math.max(1,Math.round(num('startPole')));const usable=Math.max(0,pt.poles-startPole+1);const items=expandRequirements();let sources=[...new Set(items.flatMap(requestSources))];const required={};
if(!items.length){state={assignments:[],panelsBySource:{},checks:buildChecks([],{},required,pt,usable),requiredPanelsBySource:required};renderAll();return;}
sources.forEach(s=>{let sourceItems=items.filter(it=>requestSources(it).includes(s));let slotsByBranch=0;let kw=0;sourceItems.forEach(it=>{let srcCount=requestSources(it).length;let perSourceCircuits=circuitsForSource(it,srcCount);slotsByBranch+=getBranch(it.branch).poles*perSourceCircuits;kw+=it.kwEach;});let panelsBySlots=Math.max(1,Math.ceil(slotsByBranch/usable));let panelsByKw=Math.max(1,Math.ceil(kw/pt.capacityKw));required[s]={panels:Math.max(panelsBySlots,panelsByKw),panelsBySlots,panelsByKw,kw,slotsByBranch};});
let panelsBySource={};sources.forEach(s=>panelsBySource[s]=Array.from({length:required[s].panels},(_,i)=>emptyPanel(s,i,usable)));
const assignments=[];items.forEach(it=>{let branch=getBranch(it.branch);let placements=[];let srcs=requestSources(it);let perSourceCircuits=circuitsForSource(it,srcs.length);srcs.forEach(s=>{for(let c=1;c<=perSourceCircuits;c++){let circuitItem={...it,circuitNo:c,circuits:perSourceCircuits,kwEach:it.kwEach/perSourceCircuits};let pList=panelsBySource[s]||(panelsBySource[s]=[emptyPanel(s,0,usable)]);pList.forEach(p=>p.capacity=usable);let p=choosePanel(pList,val('method'),circuitItem,branch,pt.capacityKw);if(!p){p=emptyPanel(s,pList.length,usable);pList.push(p);required[s]=required[s]||{panels:0,panelsBySlots:0,panelsByKw:0,kw:0,slotsByBranch:0};required[s].panels=pList.length;}placements.push(place(p,circuitItem,branch,startPole));}});assignments.push({...it,branchObj:branch,placements,phases:placements[0]?.phases||[]});});
state={assignments,panelsBySource,checks:buildChecks(assignments,panelsBySource,required,pt,usable),requiredPanelsBySource:required};renderAll();}
function buildChecks(assignments,panelsBySource,required,pt,usable){const checks=[];const licensed=num('licensedPower'),factor=num('opFactor')||1,allowed=licensed*factor;const uniqueLoad=uniqueKw();checks.push({level:uniqueLoad<=allowed?'good':'bad',title:'Licensed power and OP factor',msg:`Unique requested load is ${uniqueLoad.toFixed(1)} kW. Allowed provisioned power is ${allowed.toFixed(1)} kW (${licensed.toFixed(1)} kW × ${factor.toFixed(2)}).`});
assignments.forEach(a=>{let b=a.branchObj;if(!panelCompatible(pt,b))checks.push({level:'bad',title:`Voltage mismatch: ${a.cab} row ${a.row}`,msg:`${b.label} is not allowed on ${pt.label}. Pick a compatible panel or branch circuit.`});let maxCircuitKw=Math.max(0,...(a.placements||[]).map(p=>p.kwEach));if(maxCircuitKw>b.ckw)checks.push({level:'warn',title:`Circuit load over cKW: ${a.cab} row ${a.row}`,msg:`${maxCircuitKw.toFixed(1)} kW per circuit exceeds ${b.ckw.toFixed(2)} cKW for ${b.label}.`});});
Object.entries(panelsBySource).forEach(([s,panels])=>panels.forEach(p=>{checks.push({level:p.kw<=pt.capacityKw?'good':'bad',title:`Panel ${p.name}`,msg:`${p.kw.toFixed(1)} kW expected of ${pt.capacityKw.toFixed(1)} kW panel capacity; ${p.used} circuits using ${p.usedPoles}/${p.capacity} pole positions.`});}));
Object.entries(required).forEach(([s,r])=>{let placedPanels=panelsBySource[s]||[];let placedCount=placedPanels.length||r.panels;let rawMinimum=Math.max(r.panelsBySlots,r.panelsByKw);let feeds=placedPanels.flatMap(p=>p.items||[]);let feedCount=feeds.length;let uniqueFeedKw=[...new Set(feeds.map(x=>Number(x.kwEach||0)).filter(x=>x>0).map(x=>x.toFixed(2)))].map(Number);let placementText='Actual mixed-feed placement';let placementPanels=placedCount;
if(uniqueFeedKw.length===1){let feedKw=uniqueFeedKw[0];let maxFeeds=Math.max(1,Math.floor(pt.capacityKw/feedKw));placementPanels=Math.ceil(feedCount/maxFeeds);placementText=`${maxFeeds} feeds max per panel; ${feedCount} feeds / ${maxFeeds}`;}
let reason=placedCount>rawMinimum?`Using only ${rawMinimum} panel(s) would overload at least one panel.`:'Capacity and placement fit within the same panel count.';
let msg=`<div class="sizing"><span>IT load</span><b>${r.kw.toFixed(1)} kW</b><span>Panel capacity</span><b>${pt.capacityKw.toFixed(1)} kW</b><span>Panels by total kW</span><b>${r.panelsByKw}</b><span>Panels by pole space</span><b>${r.panelsBySlots}</b><span>Panels by whole-feed placement</span><b>${placementPanels}</b><span>Final required</span><b>${placedCount}</b></div><p>${esc(reason)}</p>`;
checks.push({level:'good',title:`Source ${s} required panels`,msg,html:true});});
if(assignments.length===0)checks.push({level:'bad',title:'No power requirements entered',msg:'Add requirement rows to generate panel maps and results.'});return checks;}
function syncCatalogInfo(){const pt=getPanelType();const compat=BRANCH_CIRCUITS.filter(b=>panelCompatible(pt,b)).map(b=>b.label).join(', ');byId('catalogInfo').innerHTML=`<b>${esc(pt.label)}</b><br>Capacity: <b>${pt.capacityKw.toFixed(1)} kW</b> · ${pt.poles} poles · ${pt.amps}A · compatible branch voltages: ${pt.volts.join('/')}V<br><b>Allowed branch circuits on this panel:</b> ${esc(compat)}`;let allowed=num('licensedPower')*(num('opFactor')||1);let pue=Math.max(1,num('pue')||1);byId('licenseInfo').innerHTML=`Allowed provisioned power: <b>${allowed.toFixed(1)} kW</b> = licensed power × OP factor.<br>Estimated facility load: <b>${(uniqueKw()*pue).toFixed(1)} kW</b> = IT load × PUE (${pue.toFixed(2)}). Distribution redundancy is shown separately by source.`;}
function renderAll(){renderKpis();renderRequiredInfo();renderValidation();renderUtil();renderPhase();renderAssignments();renderMaps();renderPrintable();}
function uniqueKw(){return expandRequirements().reduce((s,it)=>s+it.kwEach,0)}
function sourceKwEntries(){return Object.entries(state.panelsBySource).map(([s,panels])=>[s,panels.reduce((sum,p)=>sum+p.kw,0)]).sort((a,b)=>a[0].localeCompare(b[0]));}
function renderKpis(){const pt=getPanelType();const bad=state.checks.filter(x=>x.level==='bad').length,warn=state.checks.filter(x=>x.level==='warn').length;const panels=Object.values(state.panelsBySource).flat();const worst=Math.max(0,...panels.map(p=>p.kw/pt.capacityKw));let allowed=num('licensedPower')*(num('opFactor')||1);let facility=uniqueKw()*Math.max(1,num('pue')||1);let layoutRows=new Set(requests.map(r=>r.row).filter(Boolean)).size;let base=[['Rows',layoutRows||0,''],['Requirements',requests.length,''],['Branch circuits',totalCustomerCircuits(),''],['IT load',uniqueKw().toFixed(1)+' kW',uniqueKw()>allowed?'bad':'good'],['Facility @ PUE',facility.toFixed(1)+' kW','']];let sourceCards=sourceKwEntries().map(([s,kw])=>[`Source ${s}`,kw.toFixed(1)+' kW','']);let tail=[['Panels total',panels.length,''],['Worst panel',(worst*100).toFixed(0)+'%',worst>1?'bad':worst>.85?'warn':'good'],['Validation',bad?bad+' critical':warn?warn+' warnings':'OK',bad?'bad':warn?'warn':'good']];byId('kpis').innerHTML=base.concat(sourceCards,tail).map(k=>`<div class="kpi"><div class="v ${k[2]||''}">${k[1]}</div><div class="l">${k[0]}</div></div>`).join('');}
function renderRequiredInfo(){const pt=getPanelType();const entries=Object.entries(state.requiredPanelsBySource).map(([s,r])=>`<span class="pill pV">Source ${s}: ${r.panels} × ${pt.amps}A panels</span>`).join(' ');let src=sourceKwEntries().map(([s,kw])=>`Source ${s}: ${kw.toFixed(1)} kW`).join(' · ');let redundant=sourceKwEntries().reduce((sum,[_s,kw])=>sum+kw,0);let facility=uniqueKw()*Math.max(1,num('pue')||1);byId('requiredInfo').innerHTML=`<b>Required Infrastructure</b><br>Distribution: <b>${esc(val('distribution'))}</b> · Source set: <b>${esc(val('sourceSet'))}</b> · Panel: <b>${esc(pt.label)}</b><br>${entries||'No source panels required yet.'}<br><b>Layout rows:</b> ${[...new Set(requests.map(r=>r.row).filter(Boolean))].join(', ')||'None'}<br><b>Zones:</b> ${[...new Set(requests.map(r=>r.zone).filter(Boolean))].join(', ')||'None'}<br><div class="engnote"><b>Engineering notes</b><br>Customer IT Load: <b>${uniqueKw().toFixed(1)} kW</b> · Provisioned redundant feed capacity: <b>${redundant.toFixed(1)} kW</b> · Facility load @ PUE: <b>${facility.toFixed(1)} kW</b><br>${src}</div><br>Panel counts are based on actual cabinet/feed placement, not just total kW divided by panel capacity. Whole cabinet feeds cannot be split across panels.`;}
function renderValidation(){byId('validation').innerHTML=state.checks.map(ch=>`<div class="check ${ch.level==='good'?'':ch.level}"><h4>${ch.level==='good'?'✓':ch.level==='warn'?'⚠':'✕'} ${esc(ch.title)}</h4>${ch.html?ch.msg:`<p>${esc(ch.msg)}</p>`}</div>`).join('');}
function bar(label,pct,text,cls){return `<div class="barrow"><span>${label}</span><div class="bar"><div class="fill ${cls}" style="width:${Math.min(100,Math.max(0,pct))}%"></div></div><span>${text}</span></div>`}
function renderUtil(){const pt=getPanelType();const panels=Object.values(state.panelsBySource).flat();let avg=panels.length?panels.reduce((s,p)=>s+p.kw,0)/panels.length:0;let max=Math.max(0,...panels.map(p=>p.kw)),min=panels.length?Math.min(...panels.map(p=>p.kw)):0;let balance=panels.length&&avg?((max-min)/avg*100):0;let cards=panels.map(p=>{let pct=p.kw/pt.capacityKw*100,slot=p.capacity?p.usedPoles/p.capacity*100:0,bpct=p.bkw/pt.capacityKw*100,cls=pct>100?'red':pct>85?'amber':'green';return `<div class="util"><h3>Source ${p.source} ${p.name}<span class="pill ${pct>100?'pBad':pct>85?'pWarn':'pA'}">${pct.toFixed(0)}%</span></h3>${bar('Expected',pct,`${p.kw.toFixed(1)}/${pt.capacityKw.toFixed(1)} kW`,cls)}${bar('Provisioned bKW',bpct,`${p.bkw.toFixed(1)} kW`,'red')}${bar('Pole space',slot,`${p.usedPoles}/${p.capacity}`,'')}</div>`}).join('');let note=panels.length?`<div class="info engnote"><b>Utilization average:</b> ${avg.toFixed(1)} kW per panel · <b>Balance:</b> ${balance<=25?'Excellent':balance<=50?'Good':'Review'} (${balance.toFixed(0)}% spread vs average)</div>`:'';byId('utilCards').innerHTML=cards||'<p class="hint">No panels generated.</p>'; if(byId('utilNote')) byId('utilNote').innerHTML=note;}
function phaseTotals(){let ph=[0,0,0],cnt=[0,0,0];state.assignments.forEach(a=>a.placements.forEach(pl=>pl.phases.forEach(p=>{ph[p]+=pl.kwEach/pl.phases.length;cnt[p]++})));return {ph,cnt};}
function renderPhase(){const {ph,cnt}=phaseTotals();let max=Math.max(...ph),min=Math.min(...ph),avg=(ph[0]+ph[1]+ph[2])/3,imb=avg?((max-min)/avg*100):0;byId('phaseCards').innerHTML=['A','B','C'].map((x,i)=>`<div class="phase"><div class="pv">${ph[i].toFixed(1)} kW</div><div class="pl">Phase ${x} · ${cnt[i]} legs</div></div>`).join('');byId('phaseNote').innerHTML=`Phase imbalance: <b class="${imb>5?'bad':imb>2?'warn':'good'}">${imb.toFixed(1)}%</b> max-min vs average. Mixed 1P/2P loads can create imbalance; review striping when above target.`;}
function renderAssignments(){byId('assignBody').innerHTML=state.assignments.map(a=>{let b=a.branchObj;let status=[];if(!panelCompatible(getPanelType(),b))status.push('<span class="pill pBad">Voltage mismatch</span>');if(a.kwEach>b.ckw)status.push('<span class="pill pWarn">Over cKW</span>');if(!status.length)status.push('<span class="pill pA">OK</span>');let places=a.placements.map(p=>`<span class="pill pB">${p.source} ${p.panelName} C${p.circuit}</span>`).join('');let phases=[...new Set(a.placements.flatMap(p=>p.phases))].map(p=>'ABC'[p]).join('-');return `<tr><td><b>${esc(a.cab)}</b></td><td>Row ${a.row} · ${a.circuitNo}/${a.circuits}</td><td>${esc(b.label)}</td><td>${a.kwEach.toFixed(1)} kW</td><td>${places}</td><td>${phases}</td><td>${status.join('')}</td></tr>`}).join('')||'<tr><td colspan="7">No assignments.</td></tr>';}
function renderMaps(){const pt=getPanelType();const start=Math.max(1,Math.round(num('startPole')));const container=byId('mapsBySource');container.innerHTML=Object.entries(state.panelsBySource).map(([source,panels])=>`<h3>Source ${source} Panels</h3><div class="maps">${panels.map(p=>renderMap(p,pt,start)).join('')}</div>`).join('')||'<p class="hint">No maps generated.</p>';}
function renderMap(p,pt,start){let html=`<div class="map"><div class="maphead"><span>${p.name}</span><span>${p.usedPoles}/${p.capacity} poles · ${p.kw.toFixed(1)} kW</span></div><div class="rpp"><div class="colhdr">Odd</div><div class="colhdr">Even</div>`;for(let pos=start;pos<=pt.poles;pos+=2){[pos,pos+1].forEach(s=>{if(s>pt.poles){html+='<div></div>';return}let item=p.slots[s];let b=item?getBranch(item.branch):null;html+=item?`<div class="slot used"><div class="slotno">#${s} · ${b.poles}P · ${esc(b.label)}</div><div class="slotcab">${esc(item.cab)} · ${esc(item.row||'')} · ${esc(item.zone||'')}.${item.circuitNo}</div><div class="slotkw">${item.kwEach.toFixed(1)} kW · Ph ${item.phases.map(x=>'ABC'[x]).join('-')}</div></div>`:`<div class="slot"><div class="slotno">#${s} available</div></div>`})}return html+'</div></div>';}
function renderPrintable(){byId('printOut').innerHTML=`<h1>Opportunity Room Power Summary</h1><p><b>Customer:</b> ${esc(val('customer'))} &nbsp; <b>Opportunity:</b> ${esc(val('oppty'))} &nbsp; <b>Site:</b> ${esc(val('site'))}</p><p><b>Engineer:</b> ${esc(val('engineer'))} &nbsp; <b>Date:</b> ${esc(val('date'))} &nbsp; <b>CIM/Quote:</b> ${esc(val('ticket'))}</p><p><b>Licensed Power:</b> ${num('licensedPower').toFixed(1)} kW &nbsp; <b>OP Factor:</b> ${(num('opFactor')||1).toFixed(2)} &nbsp; <b>PUE:</b> ${(Math.max(1,num('pue')||1)).toFixed(2)} &nbsp; <b>Distribution:</b> ${esc(val('distribution'))} ${esc(val('sourceSet'))}</p><h2>Required Infrastructure</h2><div class="info">${byId('requiredInfo').innerHTML}</div><h2>Validation</h2><div class="validation">${byId('validation').innerHTML}</div><h2>Panel Utilization</h2><div class="cards">${byId('utilCards').innerHTML}</div>${byId('utilNote')?byId('utilNote').innerHTML:''}<h2>Panel Maps</h2>${byId('mapsBySource').innerHTML}`;}
function showView(id,btn){document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));byId('view-'+id).classList.add('active');document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active');}
function toggleTheme(){let t=document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark';document.documentElement.setAttribute('data-theme',t);localStorage.setItem('orc-theme',t);byId('themeBtn').textContent=t==='dark'?'Light mode':'Dark mode'}
function saveProject(){const data={project:['customer','oppty','site','engineer','date','ticket','notes','licensedPower','opFactor','pue','distribution','sourceSet','panelType','startPole','method'].reduce((o,id)=>(byId(id)?o[id]=val(id):null,o),{}),requests,cabinetLibrary,cabinetRowInfo,cabinetZoneInfo,rowRanges};download('opportunity-room-project.json',JSON.stringify(data,null,2),'application/json');}
function loadProject(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=()=>{let d=JSON.parse(r.result);Object.entries(d.project||{}).forEach(([k,v])=>{if(byId(k))byId(k).value=v});syncDistribution();Object.entries(d.project||{}).forEach(([k,v])=>{if(byId(k))byId(k).value=v});rowRanges=d.rowRanges||rowRanges;renderRowRanges();cabinetLibrary=d.cabinetLibrary||cabinetLibrary||[];cabinetRowInfo=d.cabinetRowInfo||{};cabinetZoneInfo=d.cabinetZoneInfo||{};if(!Object.keys(cabinetRowInfo).length)assignCabinetRows();requests=(d.requests||d.cabinets||[]).map(r=>({...r,row:r.row||rowForCabinet(r.cab),zone:r.zone||zoneForCabinet(r.cab)}));renderCabinetLibrary();renderRequirements();calc()};r.readAsText(f);}
function exportExcel(){let html=`<html><head><meta charset="utf-8"></head><body><h1>Opportunity Room Calculator Export</h1>${byId('printOut').innerHTML}</body></html>`;download('opportunity-room-export.xls',html,'application/vnd.ms-excel');}
function download(name,text,type){let blob=new Blob([text],{type});let a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;a.click();setTimeout(()=>URL.revokeObjectURL(a.href),500);}
function importCsvPrompt(){let txt=prompt('Paste CSV rows: Row,Zone,Cabinet,Qty,Branch ID,Circuit Qty,Expected kW Each,Source Override,PDU,Notes');if(!txt)return;txt.split(/\n+/).forEach(line=>{let parts=line.split(',');let row,zone,cab,qty,branch,circuits,kwEach,sourceOverride,pdu,notes;if(parts.length>=10){[row,zone,cab,qty,branch,circuits,kwEach,sourceOverride,pdu,notes]=parts;}else if(parts.length>=9){[row,cab,qty,branch,circuits,kwEach,sourceOverride,pdu,notes]=parts;zone=zoneForCabinet(cab);}else{[cab,qty,branch,circuits,kwEach,sourceOverride,pdu,notes]=parts;row=rowForCabinet(cab);zone=zoneForCabinet(cab);}if(cab)requests.push({row:(row||rowForCabinet(cab)||'').trim(),zone:(zone||zoneForCabinet(cab)||'Zone 1').trim(),cab:cab.trim(),qty:Number(qty)||1,branch:(branch||'208-60-3P').trim(),circuits:Number(circuits)||1,kwEach:Number(kwEach)||0,sourceOverride:(sourceOverride||'auto').trim(),pdu:pdu||'',notes:notes||''})});renderRequirements();calc();}
window.addEventListener('load',()=>{let t=localStorage.getItem('orc-theme')||'light';document.documentElement.setAttribute('data-theme',t);byId('themeBtn').textContent=t==='dark'?'Light mode':'Dark mode';init();});
</script>
