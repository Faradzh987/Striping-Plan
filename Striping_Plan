
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Circuits - Panel Provisioning</title>
<style>
:root{
  --bg:#f0f4f8;--surface:#fff;--surface-2:#f9fafb;--surface-3:#f3f4f6;
  --text:#1a2340;--muted:#6b7280;--faint:#9ca3af;--border:#e5e7eb;--border-2:#d1d5db;
  --blue:#2563eb;--blue-bg:#eff6ff;--blue-br:#bfdbfe;--blue-dark:#1e40af;
  --green:#059669;--green-bg:#d1fae5;--green-br:#6ee7b7;--green-dark:#065f46;
  --amber:#d97706;--amber-bg:#fef3c7;--amber-br:#fcd34d;
  --red:#dc2626;--red-bg:#fee2e2;--red-br:#fca5a5;
  --shadow-focus:#2563eb20;--empty-bg:#fff8f8;
}
html[data-theme="dark"]{
  --bg:#0f172a;--surface:#111827;--surface-2:#172033;--surface-3:#1f2937;
  --text:#e5e7eb;--muted:#aab2c0;--faint:#7f8898;--border:#2b3648;--border-2:#3b4658;
  --blue:#60a5fa;--blue-bg:#10233f;--blue-br:#1d4ed8;--blue-dark:#93c5fd;
  --green:#34d399;--green-bg:#06291f;--green-br:#047857;--green-dark:#a7f3d0;
  --amber:#fbbf24;--amber-bg:#2d2107;--amber-br:#b45309;
  --red:#f87171;--red-bg:#341519;--red-br:#b91c1c;
  --shadow-focus:#60a5fa30;--empty-bg:#2a1618;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:var(--text);min-height:100vh}
.header{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;gap:14px}
.back{width:36px;height:36px;background:var(--surface-3);border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:22px;color:var(--muted);flex-shrink:0}
.back:hover{border-color:var(--blue);color:var(--blue)}
.header-info{flex:1}.header-title{font-size:18px;font-weight:700;color:var(--text)}.header-sub{font-size:12px;color:var(--muted);margin-top:2px}
.badge,.theme-toggle{font-size:12px;color:var(--blue);background:var(--blue-bg);border:1px solid var(--blue-br);padding:4px 10px;border-radius:4px}
.theme-toggle{cursor:pointer;font-family:inherit;height:28px}
.layout{display:grid;grid-template-columns:340px 1fr;min-height:calc(100vh - 65px)}
.left{background:var(--surface);border-right:1px solid var(--border);padding:20px;overflow-y:auto}.right{padding:24px;overflow-y:auto}
.card{background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:14px}
.card-title{font-size:11px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;display:flex;align-items:center;gap:6px}
.cdot{width:6px;height:6px;border-radius:50%;background:var(--blue);flex-shrink:0}.cdot.green{background:var(--green)}.cdot.amber{background:var(--amber)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px}.field{margin-bottom:10px}.field:last-child{margin-bottom:0}
.flbl{font-size:11px;font-weight:600;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.04em}.hint{font-size:10px;color:var(--faint);margin-top:3px}
.iw{display:flex;align-items:stretch;border:1px solid var(--border-2);border-radius:7px;background:var(--surface);overflow:hidden;height:40px}.iw:focus-within{border-color:var(--blue);box-shadow:0 0 0 2px var(--shadow-focus)}
.iw input{flex:1;padding:0 12px;border:none;background:transparent;font-size:18px;font-weight:600;color:var(--text);outline:none;font-family:inherit;min-width:0;height:100%}.iw input[type=text]{font-size:14px}
.fu{padding:0 10px;font-size:11px;font-weight:700;color:var(--blue);background:var(--blue-bg);border-left:1px solid var(--border-2);display:flex;align-items:center;white-space:nowrap}
select{width:100%;padding:0 10px;border:1px solid var(--border-2);border-radius:7px;background:var(--surface);color:var(--text);font-size:13px;outline:none;font-family:inherit;height:40px;cursor:pointer}select:focus{border-color:var(--blue)}
.info-box{background:var(--blue-bg);border:1px solid var(--blue-br);border-radius:6px;padding:8px 12px;font-size:11px;color:var(--blue);line-height:1.6;margin-top:6px}.info-box strong{color:var(--blue-dark)}
.err{background:var(--red-bg);border:1px solid var(--red-br);border-radius:7px;padding:8px 12px;margin-bottom:12px;color:var(--red);font-size:12px;display:none;line-height:1.5}.warnbox{background:var(--amber-bg);border-color:var(--amber-br);color:var(--amber);display:block}
.sec{font-size:10px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;margin-top:20px;display:flex;align-items:center;gap:5px}.sec:first-child{margin-top:0}.rdot{width:5px;height:5px;border-radius:50%;background:var(--blue);flex-shrink:0}
.sg3{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:8px}.sg4{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:8px}.si{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:12px 14px;height:68px;display:flex;flex-direction:column;justify-content:space-between}.rv{font-size:22px;font-weight:700;color:var(--text);line-height:1}.rv.good{color:var(--green)}.rv.warn{color:var(--amber)}.rv.bad{color:var(--red)}.rl{font-size:10px;color:var(--muted);margin-top:4px}
.pcg{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:8px}.pc{border-radius:8px;padding:10px 12px;height:70px;display:flex;flex-direction:column;justify-content:space-between}.pc-a{background:var(--red-bg);border:1px solid var(--red-br)}.pc-b{background:var(--amber-bg);border:1px solid var(--amber-br)}.pc-c{background:var(--blue-bg);border:1px solid #93c5fd}.plbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em}.pc-a .plbl,.pc-a .pval{color:var(--red)}.pc-b .plbl,.pc-b .pval{color:var(--amber)}.pc-c .plbl,.pc-c .pval{color:var(--blue)}.pval{font-size:18px;font-weight:700;line-height:1.2}.psub{font-size:10px;color:var(--muted)}.imb{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 14px;margin-bottom:8px}
.pbars{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px}.pbc{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px}.pbt{font-size:11px;font-weight:700;color:var(--text);margin-bottom:8px;display:flex;justify-content:space-between;align-items:center}.pbadge{font-size:9px;padding:2px 6px;border-radius:3px;font-weight:700}.pok{background:var(--green-bg);color:var(--green);border:1px solid var(--green-br)}.pwarn{background:var(--amber-bg);color:var(--amber);border:1px solid var(--amber-br)}.pbad{background:var(--red-bg);color:var(--red);border:1px solid var(--red-br)}.br{display:flex;align-items:center;gap:8px;margin-bottom:5px}.br:last-child{margin-bottom:0}.bl{font-size:10px;color:var(--muted);width:92px;flex-shrink:0}.bt{flex:1;background:var(--surface-3);border-radius:2px;height:5px;overflow:hidden}.bf{height:100%;border-radius:2px;transition:width 0.3s}.bv{font-size:10px;color:var(--muted);width:72px;text-align:right;flex-shrink:0;font-family:monospace}
.twrap{overflow-x:auto;margin-bottom:8px}.st{width:100%;border-collapse:collapse;font-size:12px;min-width:500px}.st th{background:var(--surface-3);color:var(--text);padding:8px 12px;text-align:left;border:1px solid var(--border);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;white-space:nowrap}.st td{padding:7px 12px;border:1px solid var(--border);color:var(--text);vertical-align:middle}.st tr:hover td{background:var(--surface-2)}.pill{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;white-space:nowrap;margin:1px}.pa{background:var(--green-bg);color:var(--green-dark);border:1px solid var(--green-br)}.pb{background:var(--blue-bg);color:var(--blue-dark);border:1px solid #93c5fd}.cn{font-weight:600;color:var(--text);font-size:12px}.lv{font-family:monospace;color:var(--text);font-size:12px}
.legend{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:8px}.li{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--muted)}.ld{width:8px;height:8px;border-radius:2px;flex-shrink:0}
.panels-row{display:flex;flex-wrap:wrap;gap:16px;margin-bottom:16px}.pmw{flex:0 0 auto}.pm-title{font-size:11px;font-weight:700;color:var(--text);padding:6px 10px;background:var(--surface-3);border:1px solid var(--border);border-radius:6px 6px 0 0;display:flex;justify-content:space-between;align-items:center;min-width:260px}.pm-title.red{background:var(--green-bg);border-color:var(--green-br);color:var(--green-dark)}.pm-badge{font-size:9px;padding:1px 6px;border-radius:3px;font-weight:600;background:var(--blue-bg);color:var(--blue-dark);border:1px solid #93c5fd}.pm-badge.green{background:var(--green-bg);color:var(--green-dark);border:1px solid var(--green-br)}.rpp{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--surface-3);border:1px solid var(--border);border-radius:0 0 8px 8px;padding:6px;min-width:260px;max-width:300px}.rpp-hdrs{grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-bottom:3px;padding-bottom:3px;border-bottom:1px solid var(--border)}.rpp-col-lbl{font-size:9px;font-weight:700;color:var(--faint);text-transform:uppercase;letter-spacing:0.06em;text-align:center}.slot{border-radius:3px;padding:4px 6px;min-height:34px;display:flex;flex-direction:column;justify-content:center;font-size:10px;line-height:1.3}.slot-pos{font-size:8px;color:var(--faint);margin-bottom:1px}.slot-cab{font-size:10px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:110px;color:inherit}.slot-info{font-size:8px;opacity:0.8}.s-empty{background:var(--surface);border:1px dashed var(--border)}.s-a{background:var(--green-bg);border:1px solid var(--green-br);color:var(--green-dark)}.s-b{background:var(--blue-bg);border:1px solid #93c5fd;color:var(--blue-dark)}
.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:300px;gap:10px;text-align:center}
.reset{width:100%;padding:10px;background:var(--surface);border:1px solid var(--border);border-radius:7px;font-size:13px;color:var(--muted);cursor:pointer;font-family:inherit}
@media(max-width:900px){.layout{grid-template-columns:1fr}.left{border-right:none;border-bottom:1px solid var(--border)}.sg4,.sg3,.pbars,.pcg{grid-template-columns:1fr}.header{flex-wrap:wrap}}
</style>
</head>
<body>
<div class="header">
  <a href="calculators.html" class="back">&#8249;</a>
  <div class="header-info"><div class="header-title">Circuit Provisioning</div><div class="header-sub">Panel assignment, striping plan &amp; visual panel map</div></div>
  <button class="theme-toggle" onclick="toggleTheme()" id="theme-toggle">Dark mode</button>
  <span class="badge">Field Engineering</span>
</div>
<div class="layout">
  <div class="left">
    <div class="err" id="err"></div><div class="err warnbox" id="warn" style="display:none"></div>
    <div class="card"><div class="card-title"><span class="cdot green"></span>Circuit Type</div><div class="field"><div class="flbl">Select Circuit</div><select id="circuit-type" onchange="onCircuitChange()"><option value="208-60-3P">208V 60A 3-pole</option><option value="208-30-3P">208V 30A 3-pole</option><option value="208-20-3P">208V 20A 3-pole</option><option value="208-60-2P">208V 60A 2-pole</option><option value="208-30-2P" selected>208V 30A 2-pole</option><option value="208-20-2P">208V 20A 2-pole</option><option value="208-60-1P">208V 60A 1-pole</option><option value="208-30-1P">208V 30A 1-pole</option><option value="208-20-1P">208V 20A 1-pole</option><option value="120-30-1P">120V 30A 1-pole</option><option value="120-20-1P">120V 20A 1-pole</option></select><div id="circuit-info" class="info-box"></div></div><div class="g2"><div class="field"><div class="flbl">Circuits / Cabinet</div><div class="iw"><input type="number" id="cpc" value="2" min="1" max="10" oninput="calc()"><span class="fu">#</span></div><div class="hint">e.g. 2 for dual PDU</div></div><div class="field"><div class="flbl">Feed Type</div><select id="feed-type" onchange="calc()"><option value="redundant">A+B Redundant</option><option value="single">Single feed</option></select></div></div><div class="field" style="margin-top:8px"><div class="flbl">Expected Draw / Circuit <span style="color:var(--amber);font-size:10px;font-weight:400;text-transform:none">actual load</span></div><div class="iw"><input type="number" id="expected-draw" value="4" min="0.1" max="100" step="0.1" oninput="calc()"><span class="fu">kW</span></div><div class="hint">Validated against selected circuit cKW / 80% rating</div></div></div>
    <div class="card"><div class="card-title"><span class="cdot"></span>Cabinets</div><div class="g2"><div class="field"><div class="flbl">Number of Cabinets</div><div class="iw"><input type="number" id="num-cabs" value="20" min="1" max="500" oninput="calc()"><span class="fu">#</span></div></div><div class="field"><div class="flbl">Cabinet Prefix</div><div class="iw"><input type="text" id="prefix" value="CAB" oninput="calc()"></div></div></div></div>
    <div class="card"><div class="card-title"><span class="cdot"></span>Panel Configuration</div><div class="g2"><div class="field"><div class="flbl">Number of Panels / Feed</div><div class="iw"><input type="number" id="num-panels" value="2" min="1" max="20" oninput="calc()"><span class="fu">#</span></div></div><div class="field"><div class="flbl">Panel Capacity <span style="color:var(--muted);font-size:10px;font-weight:400;text-transform:none">kW per panel</span></div><div class="iw"><input type="number" id="panel-cap" value="65" min="1" max="1000" step="1" oninput="calc()"><span class="fu">kW</span></div></div></div><div class="g2"><div class="field"><div class="flbl">Panel Size</div><select id="panel-size" onchange="calc()"><option value="42" selected>42 slots</option><option value="48">48 slots</option><option value="60">60 slots</option><option value="84">84 slots</option></select></div><div class="field"><div class="flbl">Poles</div><select id="poles" onchange="calc()"><option value="1">1-pole</option><option value="2" selected>2-pole</option><option value="3">3-pole</option></select></div></div><div id="panel-info" class="info-box"></div></div>
    <div class="card"><div class="card-title"><span class="cdot amber"></span>Striping</div><div class="field"><div class="flbl">Distribution</div><select id="method" onchange="calc()"><option value="roundrobin">Round-robin (balanced)</option><option value="sequential">Sequential (fill A then B)</option></select></div><div class="field"><div class="flbl">Starting Circuit #</div><div class="iw"><input type="number" id="start" value="1" min="1" max="84" oninput="calc()"><span class="fu">#</span></div></div></div>
    <button onclick="clearAll()" class="reset">Reset</button>
  </div>
  <div class="right"><div id="empty" class="empty"><svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.2" opacity="0.3"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg><p style="font-size:12px;color:var(--faint)">Configure inputs to generate panel plan</p></div><div id="results" style="display:none"><div class="sec"><span class="rdot"></span>Summary</div><div class="sg4"><div class="si"><div class="rv" id="r-need">--</div><div class="rl">Primary circuits needed</div></div><div class="si"><div class="rv" id="r-avail">--</div><div class="rl">Circuits available / feed</div></div><div class="si"><div class="rv" id="r-hdroom">--</div><div class="rl">Circuit slot headroom</div></div><div class="si"><div class="rv" id="r-pneed">--</div><div class="rl">Panels needed / feed</div></div></div><div class="sg3"><div class="si"><div class="rv" id="r-totkw">--</div><div class="rl">Total expected IT load</div></div><div class="si"><div class="rv" id="r-pconf">--</div><div class="rl">Panels configured total</div></div><div class="si"><div class="rv" id="r-cpc">--</div><div class="rl">Circuits per cabinet</div></div></div><div class="sec"><span class="rdot"></span>Panel Utilization</div><div class="pbars" id="pbars"></div><div class="sec"><span class="rdot"></span>Phase Balance</div><div class="pcg"><div class="pc pc-a"><div class="plbl">Phase A</div><div class="pval" id="ph-a">--</div><div class="psub" id="ph-a-s">--</div></div><div class="pc pc-b"><div class="plbl">Phase B</div><div class="pval" id="ph-b">--</div><div class="psub" id="ph-b-s">--</div></div><div class="pc pc-c"><div class="plbl">Phase C</div><div class="pval" id="ph-c">--</div><div class="psub" id="ph-c-s">--</div></div></div><div class="imb" id="imb"></div><div class="sec"><span class="rdot"></span>Striping Plan</div><div class="legend" id="legend"></div><div class="twrap"><table class="st"><thead id="st-head"></thead><tbody id="st-body"></tbody></table></div><div class="sec" style="margin-top:24px"><span class="rdot"></span>Primary Panels</div><div style="font-size:11px;color:var(--muted);margin-bottom:10px">Odd positions left - Even positions right - RPP format</div><div id="primary-maps" class="panels-row"></div><div id="redundant-section" style="display:none"><div class="sec" style="margin-top:4px;color:var(--green)"><span style="width:5px;height:5px;border-radius:50%;background:var(--green);display:inline-block;margin-right:5px"></span>Redundant Panels</div><div id="redundant-maps" class="panels-row"></div></div></div></div>
</div>
<script>
var CIRCUITS=[{k:'208-60-3P',l:'208V 60A 3-pole',bkw:21.59,ckw:17.27,amp:60,vol:208,poles:3,ph:1.732},{k:'208-30-3P',l:'208V 30A 3-pole',bkw:10.80,ckw:8.64,amp:30,vol:208,poles:3,ph:1.732},{k:'208-20-3P',l:'208V 20A 3-pole',bkw:7.20,ckw:5.76,amp:20,vol:208,poles:3,ph:1.732},{k:'208-60-2P',l:'208V 60A 2-pole',bkw:12.48,ckw:9.98,amp:60,vol:208,poles:2,ph:1},{k:'208-30-2P',l:'208V 30A 2-pole',bkw:6.24,ckw:4.99,amp:30,vol:208,poles:2,ph:1},{k:'208-20-2P',l:'208V 20A 2-pole',bkw:4.16,ckw:3.33,amp:20,vol:208,poles:2,ph:1},{k:'208-60-1P',l:'208V 60A 1-pole',bkw:12.48,ckw:9.98,amp:60,vol:208,poles:1,ph:1},{k:'208-30-1P',l:'208V 30A 1-pole',bkw:6.24,ckw:4.99,amp:30,vol:208,poles:1,ph:1},{k:'208-20-1P',l:'208V 20A 1-pole',bkw:4.16,ckw:3.33,amp:20,vol:208,poles:1,ph:1},{k:'120-30-1P',l:'120V 30A 1-pole',bkw:3.60,ckw:2.88,amp:30,vol:120,poles:1,ph:1},{k:'120-20-1P',l:'120V 20A 1-pole',bkw:2.40,ckw:1.92,amp:20,vol:120,poles:1,ph:1}];
function getCircuit(){var k=document.getElementById('circuit-type').value;return CIRCUITS.find(function(x){return x.k===k})||CIRCUITS[4]}
function gv(id){return parseFloat(document.getElementById(id).value)||0}function gs(id){return document.getElementById(id).value}function setEl(id,v){document.getElementById(id).textContent=v}function setCls(id,c){document.getElementById(id).className='rv '+c}function pname(i){return 'Panel '+String.fromCharCode(65+i)}function pad(n){return n<10?'00'+n:n<100?'0'+n:''+n}function setBox(id,m){var e=document.getElementById(id);e.textContent=m;e.style.display=m?'block':'none'}function esc(s){return String(s).replace(/[&<>'"]/g,function(ch){return {'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[ch]})}
function setTheme(t){document.documentElement.setAttribute('data-theme',t);localStorage.setItem('circuitTheme',t);document.getElementById('theme-toggle').textContent=t==='dark'?'Light mode':'Dark mode'}function toggleTheme(){setTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark')}
function phasesForCircuit(circuitNumber,poles){var n=(circuitNumber-1)%3;if(poles===3)return[0,1,2];if(poles===2)return[n,(n+1)%3];return[n]}
function onCircuitChange(){var c=getCircuit();document.getElementById('circuit-info').innerHTML='<strong>'+c.amp+'A - '+c.vol+'V - '+c.poles+'-pole</strong> &nbsp;-&nbsp; bKW: '+c.bkw.toFixed(2)+' &nbsp;-&nbsp; cKW / 80%: '+c.ckw.toFixed(2)+' kW';document.getElementById('poles').value=c.poles;calc()}
function calc(){var c=getCircuit(),cpc=Math.max(1,Math.round(gv('cpc'))),ft=gs('feed-type'),nc=Math.max(1,Math.round(gv('num-cabs'))),np=Math.max(1,Math.round(gv('num-panels'))),cpp=parseInt(gs('panel-size'))||42,poles=parseInt(gs('poles'))||c.poles,mth=gs('method'),stc=Math.max(1,Math.round(gv('start'))),pfx=document.getElementById('prefix').value||'CAB',expDraw=gv('expected-draw')||0,panelCapKw=gv('panel-cap')||0;
  setBox('err','');setBox('warn','');
  var warnings=[];if(poles!==c.poles){warnings.push('Selected pole count does not match circuit type. Resetting poles to '+c.poles+'-pole.');poles=c.poles;document.getElementById('poles').value=poles}
  var circPerPanel=Math.floor((cpp-stc+1)/poles);if(circPerPanel<1){setBox('err','Starting circuit # leaves no valid '+poles+'-pole positions in a '+cpp+'-slot panel.');document.getElementById('empty').style.display='flex';document.getElementById('results').style.display='none';return}
  if(expDraw>c.ckw)warnings.push('Expected draw '+expDraw.toFixed(1)+' kW exceeds selected circuit cKW / 80% rating of '+c.ckw.toFixed(2)+' kW.');
  if(panelCapKw<=0){setBox('err','Panel capacity must be greater than 0 kW.');return}
