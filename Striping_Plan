}.pBad{background:var(--red2);color:var(--red);border:1px solid color-mix(in srgb,var(--red),transparent 55%)}.pV{background:var(--violet2);color:var(--violet);border:1px solid color-mix(in srgb,var(--violet),transparent 55%)}.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px}.util{background:var(--card2);border:1px solid var(--line);border-radius:12px;padding:12px}.util h3{font-size:14px;margin:0 0 10px;display:flex;justify-content:space-between;gap:8px}.barrow{display:grid;grid-template-columns:96px 1fr 70px;align-items:center;gap:8px;margin:7px 0}.barrow span{font-size:11px;color:var(--muted)}.bar{height:7px;background:var(--line);border-radius:4px;overflow:hidden}.fill{height:100%;background:var(--blue);border-radius:4px}.fill.green{background:var(--green)}.fill.amber{background:var(--amber)}.fill.red{background:var(--red)}.maps{display:flex;flex-wrap:wrap;gap:14px}.map{width:310px;background:var(--card2);border:1px solid var(--line);border-radius:12px;overflow:hidden}.maphead{padding:9px 11px;background:var(--card);border-bottom:1px solid var(--line);font-weight:800;font-size:12px;display:flex;justify-content:space-between;gap:8px;align-items:center}.rpp{display:grid;grid-template-columns:1fr 1fr;gap:3px;padding:8px}.colhdr{font-size:9px;text-align:center;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);padding-bottom:3px}.slot{min-height:38px;border:1px dashed var(--line2);border-radius:6px;background:var(--card);padding:5px;display:flex;flex-direction:column;justify-content:center}.slot.used{background:var(--green2);border-style:solid;border-color:color-mix(in srgb,var(--green),transparent 60%)}.slotno{font-size:9px;color:var(--muted)}.slotcab{font-size:10px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.slotkw{font-size:9px;color:var(--muted)}.validation{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px}.check{background:var(--card2);border:1px solid